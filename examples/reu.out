/*** Query    (0000000 milisegundos) ******CONTEXT@trg8B50,TRIGGER_IBPME#DA838EC7-601D-47E2-BD62-05B7BD9A541B,UPDATE_LOGICA_PROCESOS,,06/07/26 10:18:20,241,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
