EGACIONTC_ID = 885) AND CT.ISANULATED_FL <> 1 AND NOT EXISTS(SELECT 1 FROM TIM_INCAPACIDADTEMPORALTC Y 	WHERE Y.CONTRATOTC_ID = C.CONTRATOTC_ID AND ISNULL(Y.ANULADA_FL,0) = 0 	AND C.ALTA_DT >= Y.INICIO_DT 	AND (C.ALTA_DT <=Y.FIN_DT OR Y.FIN_DT IS NULL)) AND NOT EXISTS(SELECT 1 FROM TIM_SUSPENSIONCONTRATOTC Y 	WHERE Y.CONTRATOTC_ID = C.CONTRATOTC_ID 	AND C.ALTA_DT >= Y.INICIO_DT 	AND (C.ALTA_DT <=Y.FIN_DT OR Y.FIN_DT IS NULL)) AND (CONVERT(DATE, C.ALTA_DT) <= CT.FIN_REAL_DT OR CT.FIN_REAL_DT IS NULL) AND ( ( 'D' = 'D' 	AND C.ALTA_DT BETWEEN 			CONVERT(datetime,CONVERT(DATE,{ts '2026-07-06 10:18:06.078'})) 			AND 	 			DATEADD(DD,1,CONVERT(datetime,CONVERT(DATE,{ts '2026-07-06 10:18:06.078'}))) ) OR ( 'D' = 'P' 	AND C.ALTA_DT BETWEEN 			CONVERT(datetime,CONVERT(DATE,NULL)) 			AND 	 			DATEADD(DD,1,CONVERT(datetime,CONVERT(DATE,NULL))) ) ) AND ( CT.TURNO_ESPECIAL_FL = 1 OR ( 'D' = 'D' 	AND EXISTS(SELECT 1 FROM TIM_HORARIOCONTRATOTC Z 				WHERE Z.CONTRATOTC_ID = C.CONTRATOTC_ID 	AND HORA_INI_CD < convert(char(5), {ts '2026-07-06 10:18:06.078'}, 108)) ) OR 'D' = 'P' ) ORDER BY C.CONTRATOTC_ID 
go

/*** Query    (0000078 milisegundos) ******CONTEXT@    1,AP_PRESENCIA#105505,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:06,372,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT C.CONTRATOSTIPOCONFLICTO_ID,C.TIPO_CONFLICTO_CD,C.CONTRATOTC_ID,(SELECT (SELECT Y.MOVIL_CD FROM TIM_EMPLEADO Y WHERE Y.EMPLEADOTC_ID = X.EMPLEADOTC_ID) FROM TIM_CONTRATO X WHERE X.CONTRATOTC_ID = C.CONTRATOTC_ID) AS MOVIL_CD, (SELECT X.NOMBRE_DS + ' ' + X.APELLIDOS_DS FROM TIM_EMPLEADO X WHERE X.EMPLEADOTC_ID IN (SELECT Y.EMPLEADOTC_ID FROM TIM_CONTRATO Y WHERE Y.CONTRATOTC_ID = C.CONTRATOTC_ID)) AS NOMBRE_EMPLEADO_DS, (SELECT COUNT(*) FROM TIM_CONFLICTOFICHAJETC X WHERE X.TIPO_CONFLICTO_CD = C.TIPO_CONFLICTO_CD AND X.CONTRATOTC_ID = C.CONTRATOTC_ID) AS NUMERO_CONFLICTOS_NM FROM TIM_CONTRATOSTIPOCONFLICTO C  WHERE C.CONTRATOTC_ID IN ( 	SELECT X.CONTRATOTC_ID FROM TIM_CONTRATO X WHERE 	( 		( 			(885 IS NOT NULL AND X.DELEGACIONTC_ID = 885) OR 885 IS NULL 		) 		AND 		( 			(NULL IS NOT NULL AND (X.CLIENTETC_ID = NULL OR X.CLIENTETC_ID IS NULL)) OR NULL IS NULL 		) 		AND 		( 			(NULL IS NOT NULL AND (X.DOMICILIOCLIENTETC_ID = NULL OR X.DOMICILIOCLIENTETC_ID IS NULL)) OR NULL IS NULL 		) 		AND 		( 			( 				NULL IS NOT NULL AND 				( 					(X.SUBCUENTADOMICILIOTC_ID = NULL AND NOT EXISTS (SELECT 1 FROM TIM_REVISIONCONTRATO Y WHERE Y.TYPE_REVISION_CD = '07' AND Y.CONTRATOTC_ID = X.CONTRATOTC_ID)) 					OR 					(X.SUBCUENTADOMICILIOTC_ID IS NULL AND NOT EXISTS (SELECT 1 FROM TIM_REVISIONCONTRATO Y WHERE Y.TYPE_REVISION_CD = '07' AND Y.CONTRATOTC_ID = X.CONTRATOTC_ID)) 					OR 					(EXISTS 						(SELECT 1 FROM TIM_REVISIONCONTRATO Y WHERE Y.TYPE_REVISION_CD = '07' AND Y.CONTRATOTC_ID = X.CONTRATOTC_ID AND Y.SUBCUENTADOMICILIOTC_ID = NULL) 					) 				) 			) 			OR 			NULL IS NULL 		) 	) ) AND (SELECT COUNT(*) FROM TIM_CONFLICTOFICHAJETC X WHERE X.TIPO_CONFLICTO_CD = C.TIPO_CONFLICTO_CD AND X.CONTRATOTC_ID = C.CONTRATOTC_ID) > 0 
go

/*** Query    (0000063 milisegundos) ******CONTEXT@    1,AP_PRESENCIA#105505,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:06,547,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT A.AUSENCIA_ID,A.AUSENCIA_DT,A.FECHA_INICIO_DT,A.FECHA_FIN_DT,A.DESCRIPCION_DS,A.GESTIONADA_FL,A.TIPO_AUSENCIA_CD,A.CONTRATOTC_ID,A.MAINFILE_ID,A.DELEGACIONTC_ID,A.EMPLEADOTC_ID,A.ALTA_USR,A.ALTA_DT,A.MOD_USR,A.MOD_DT,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = A.MOD_USR) AS MOD_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = A.ALTA_USR) AS ALTA_DS, E.NOMBRE_DS + ' ' + E.APELLIDOS_DS AS NOMBRE_EMPLEADO_DS, CT.NUMERO_CONTRATO_CD AS NUMERO_CONTRATO_CD, CL.CLIENTETC_DS AS CLIENTETC_DS, E.MOVIL_CD AS MOVIL_CD, CT.CLIENTETC_ID AS CLIENTE_ID, (case 	when Exists	(SELECT 1 FROM TIM_IMAGENTC X WHERE X.AUSENCIA_ID = A.AUSENCIA_ID) then 1 	else 0 end) AS TIENEIMAGENES_FL, CT.INICIO_DT AS INICIO_CONTRATO_DT, CL.CIF_CD AS CIF_CD, DL.NOMBRE_DS AS DELEGACION_DS, DL.DELEGACIONTC_CD AS DELEGACION_CD, E.USR_CD AS USR_CD,(SELECT (SELECT Y.EMPLEADOTC_CD FROM TIM_EMPLEADO Y WHERE Y.EMPLEADOTC_ID = X.EMPLEADOTC_ID) FROM TIM_CONTRATO X WHERE X.CONTRATOTC_ID = A.CONTRATOTC_ID) AS EMPLEADOTC_CD,A.AUSENCIA_DT FROM TIM_AUSENCIA A INNER JOIN TIM_CONTRATO CT ON CT.CONTRATOTC_ID = A.CONTRATOTC_ID INNER JOIN TIM_CLIENTETC CL ON CL.CLIENTETC_ID = CT.CLIENTETC_ID INNER JOIN TIM_DELEGACION DL ON DL.DELEGACIONTC_ID = A.DELEGACIONTC_ID INNER JOIN TIM_EMPLEADO E ON E.EMPLEADOTC_ID = A.EMPLEADOTC_ID  WHERE A.DELEGACIONTC_ID = 885 AND ( ( 'D' = 'D' AND A.AUSENCIA_DT = CONVERT(DATE,{ts '2026-07-06 10:18:06.078'}) ) OR ( 'D' = 'P' AND 	A.AUSENCIA_DT BETWEEN CONVERT(datetime,CONVERT(date,NULL)) AND CONVERT(datetime,CONVERT(date,NULL)) ) ) AND EXISTS(SELECT 1 FROM TIM_DELEGACIONESDOMICILIOS Y WHERE Y.DOMICILIOCLIENTETC_ID = CT.DOMICILIOCLIENTETC_ID AND Y.DELEGACIONTC_ID = 885) ORDER BY A.AUSENCIA_DT DESC 
go

/*** Query    (0000000 milisegundos) ******CONTEXT@    1,AP_PRESENCIA#105505,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:06,555,D:\ADSP\SERVICES\ADECCO4U\Program\SesionAdecco\funciones\f_sessionadecco.cor,2021;****************************************/
SELECT D.DELEGACIONTC_ID,D.NOMBRE_DS,D.TIPO_DELEGACION_CD,D.MES_CERRADO_DT,D.DELEGACIONTC_CD,D.DELEGACION_DR_ID,D.DELEGACION_DR_CD,D.IS_STAFFING_FL,D.CONTACTO_EMPLEADO2_ID,D.TIPONIVELACCESO_CD,D.ISGGCC_FL,D.ADECCOHOLDING_CD,D.SINCRO_PROFA_FL,D.TELEFONO1_CD,D.TELEFONO2_CD,D.FAX_CD,D.CODE,D.INTEGRACIONOLE_FL,D.BEGINNINGDATE_DT,D.ENDINGDATE_DT,D.ALTA_USR,D.ALTA_DT,D.MOD_USR,D.MOD_DT, (D.DELEGACIONTC_CD + ' - ' + D.NOMBRE_DS) AS COMBINADO_DELEGACION_DS,(SELECT X.TIPONIVELACCESO_DS FROM TIM_TIPONIVELACCESO X WHERE X.TIPONIVELACCESO_CD = D.TIPONIVELACCESO_CD) AS TIPONIVELACCESO_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = D.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = D.MOD_USR) AS MOD_DS, (CASE WHEN EXISTS(SELECT 1 FROM ACP_ADECCO_HOLDING X WHERE X.ADECCOHOLDING_CD = D.ADECCOHOLDING_CD AND X.OS_FL = 1) THEN 1 ELSE 0 END) AS IS_OS_FL,'0' FROM TIM_DELEGACION D WHERE D.DELEGACIONTC_ID = 885 
go

