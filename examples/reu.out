SELECT C.CARGA_ORGOS_ID,C.CLIENTETC_ID,C.ESTADO_CD,C.ESTADO_DT,C.FILENAME_DS,C.DELEGACIONTC_ID,C.ALTA_USR,C.ALTA_DT,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = C.ALTA_USR) AS ALTA_DS, (SELECT X.CLIENTETC_DS + ' ('+ X.CIF_CD + ')' FROM TIM_CLIENTETC X WHERE X.CLIENTETC_ID = C.CLIENTETC_ID)  AS CLIENTETC_DS, (SELECT D.DELEGACIONTC_CD + ' - ' + D.NOMBRE_DS FROM TIM_DELEGACION D WHERE D.DELEGACIONTC_ID = C.DELEGACIONTC_ID) AS DELEGACION_DS,C.CARGA_ORGOS_ID FROM ACP_CARGA_ORGOS C  WHERE C.ESTADO_CD = 'EN_COLA' ORDER BY C.CARGA_ORGOS_ID 
go

