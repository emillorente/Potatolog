/*** Query    (0000000 milisegundos) ******CONTEXT@    1,AP_CMDELEGACION#107651,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:20,638,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT P.PANEL_ID,P.PANEL_CD,P.PANEL_DS,P.TIPO_CD,P.FILENAME_DS,P.WDG_TYPE_CD,P.DESARROLLO_FL,P.EDITABLE_FL,P.ALTA_USR,P.ALTA_DT,P.MOD_USR,P.MOD_DT, ( CASE P.DESARROLLO_FL 	WHEN 1 THEN 'XPRT_' + P.PANEL_CD 	ELSE P.PANEL_CD END ) AS PANEL_XPRT_CD,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = P.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = P.MOD_USR) AS MOD_DS, ( CASE 	WHEN (P.DESARROLLO_FL = 1) THEN 0 	WHEN (P.EDITABLE_FL = 0) THEN 0 	ELSE 1 END ) AS EDIT_IMPORT_FL,P.PANEL_DS FROM PAN_PANEL P  WHERE P.PANEL_ID IN ( SELECT X.PANEL_ID FROM PAN_PANEL_AP X WHERE 	X.ACCESSPOINT_ID = 107651 ) ORDER BY P.PANEL_DS 
go

/*** Query    (0000000 milisegundos) ******CONTEXT@    1,AP_CMDELEGACION#107651,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:20,638,D:\ADSP\SERVICES\ADECCO4U\Program\TimeCapture\funciones\f_ap_cmdelegacion.cor,162;****************************************/
SELECT D.DELEGACIONTC_ID,D.NOMBRE_DS,D.TIPO_DELEGACION_CD,D.MES_CERRADO_DT,D.DELEGACIONTC_CD,D.DELEGACION_DR_ID,D.DELEGACION_DR_CD,D.IS_STAFFING_FL,D.CONTACTO_EMPLEADO2_ID,D.TIPONIVELACCESO_CD,D.ISGGCC_FL,D.ADECCOHOLDING_CD,D.SINCRO_PROFA_FL,D.TELEFONO1_CD,D.TELEFONO2_CD,D.FAX_CD,D.CODE,D.INTEGRACIONOLE_FL,D.BEGINNINGDATE_DT,D.ENDINGDATE_DT,D.ALTA_USR,D.ALTA_DT,D.MOD_USR,D.MOD_DT, (D.DELEGACIONTC_CD + ' - ' + D.NOMBRE_DS) AS COMBINADO_DELEGACION_DS,(SELECT X.TIPONIVELACCESO_DS FROM TIM_TIPONIVELACCESO X WHERE X.TIPONIVELACCESO_CD = D.TIPONIVELACCESO_CD) AS TIPONIVELACCESO_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = D.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = D.MOD_USR) AS MOD_DS, (CASE WHEN EXISTS(SELECT 1 FROM ACP_ADECCO_HOLDING X WHERE X.ADECCOHOLDING_CD = D.ADECCOHOLDING_CD AND X.OS_FL = 1) THEN 1 ELSE 0 END) AS IS_OS_FL,'0' FROM TIM_DELEGACION D WHERE D.DELEGACIONTC_ID = 885 
go

/*** Query    (0000016 milisegundos) ******CONTEXT@    1,AP_CMDELEGACION#107651,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:20,672,D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor,164;****************************************/
SELECT COUNT (DISTINCT C.EMPLEADOTC_ID) AS PASS,COUNT (DISTINCT C.CLIENTETC_ID) AS CLIENTES FROM TIM_CONTRATO C WHERE C.ISANULATED_FL = 0 AND C.INICIO_DT <= GETDATE() AND (C.FIN_REAL_DT IS NULL OR C.FIN_REAL_DT >=GETDATE()) AND C.DELEGACIONTC_ID = 885
go

/*** Query    (0000000 milisegundos) ******CONTEXT@    1,AP_CMDELEGACION#107651,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:20,682,D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor,164;****************************************/
SELECT SUM(CASE WHEN A.INICIO_DT < CAST(GETDATE() AS date) THEN A.TOTAL ELSE 0 END) AS POS_VENCIDOS,  SUM(CASE WHEN A.INICIO_DT BETWEEN CAST(GETDATE() AS date) AND DATEADD(DD,6,CAST(GETDATE() AS date)) THEN A.TOTAL ELSE 0 END) AS POS_INMEDIATOS, SUM(CASE WHEN A.INICIO_DT > DATEADD(DD,6,CAST(GETDATE() AS date)) THEN A.TOTAL ELSE 0 END) AS POS_PROXIMOS FROM (     SELECT INICIO_DT,ISNULL(RENOVACION_FL,0) AS RENOVACION,CANTIDAD_NM-     (SELECT COUNT(*) FROM ACP_EMPLEADO_PETICION EP WHERE EP.PETICIONACP_ID = P.PETICIONACP_ID) -     ISNULL((SELECT SUM(H.PLAZAS_NOCUBIERTAS_NM) FROM ACP_NOCUBIERTO_PETICION H WHERE      H.PETICIONACP_ID = P.PETICIONACP_ID),0) AS TOTAL     FROM ACP_PETICIONACP P        WHERE P.ESTADO_CD IN ('PENDIENTE','CURSO','COMPLETADO','CONTRATADO')      AND P.DELEGACIONTC_ID = 885  ) AS A
go

/*** Query    (0000015 milisegundos) ******CONTEXT@    1,AP_CMDELEGACION#107651,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:20,689,D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor,164;****************************************/
SELECT SUM(CASE WHEN A.FIN_PREVISTO_DT < CAST(GETDATE() AS DATE) THEN 1 ELSE 0 END) AS VENCIDAS,  SUM(CASE WHEN A.FIN_PREVISTO_DT BETWEEN CAST(GETDATE() AS DATE) AND DATEADD(DD,2,CAST(GETDATE() AS DATE)) THEN 1 ELSE 0 END) AS PROXIMAS FROM (  SELECT FIN_PREVISTO_DT  FROM TIM_CONTRATO C WHERE C.DELEGACIONTC_ID = 885 AND C.ISANULATED_FL = 0 AND C.FIN_REAL_DT IS NULL AND C.FIN_PREVISTO_DT <= DATEADD(DD,2,CAST(GETDATE() AS DATE)) ) AS A
go

/*** Query    (0000000 milisegundos) ******CONTEXT@    1,AP_CMDELEGACION#107651,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:20,702,D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor,164;****************************************/
SELECT  SUM(CASE WHEN A.EXPIRACION_DT IS NULL OR A.EXPIRACION_DT < CAST(GETDATE() AS DATE) THEN 1 ELSE 0 END) AS CADUCADOS,  SUM(CASE WHEN A.EXPIRACION_DT >= CAST(GETDATE() AS DATE) THEN 1 ELSE 0 END) AS PROX_CADUCIDAD FROM (  SELECT D.EXPIRACION_DT FROM TIM_DOCUMENTACION_EMPLEADO D WHERE D.EMPLEADOTC_ID IN (SELECT C.EMPLEADOTC_ID FROM TIM_CONTRATO C      WHERE C.DELEGACIONTC_ID = 885      AND C.ISANULATED_FL = 0       AND (C.FIN_REAL_DT IS NULL OR C.FIN_REAL_DT >=GETDATE()) ) AND (D.EXPIRACION_DT IS NULL OR D.EXPIRACION_DT <= DATEADD(DD,30,CAST(GETDATE() AS DATE))) AND D.TIPODOCUMENTO_ID IN (1,2) ) AS A
go

/*** Query    (0000015 milisegundos) ******CONTEXT@    1,AP_CMDELEGACION#107651,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:20,723,D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor,164;****************************************/
SELECT COUNT(*) AS BOLETIN_PEND_TOTAL,SUM(ISTIMECAPTURE_FL) AS BOLETIN_PEND_TC FROM ( SELECT CASE WHEN EXISTS(SELECT 1     FROM TIM_DELEGACIONESDOMICILIOS DD     WHERE DD.DELEGACIONTC_ID = B.DELEGACIONTC_ID     AND DD.DOMICILIOCLIENTETC_ID = CT.DOMICILIOCLIENTETC_ID     AND DD.IS_TIME_CAPTURE_FL = 1 ) THEN 1 ELSE 0 END AS ISTIMECAPTURE_FL FROM TIM_BOLETIN B  INNER JOIN TIM_CONTRATO CT ON CT.CONTRATOTC_ID = B.CONTRATOTC_ID WHERE B.ESTADO_CD = 'PENDIENTE'  AND B.DELEGACIONTC_ID = 885  AND B.FIN_DT BETWEEN (SELECT DATEADD(MONTH,1,MES_CERRADO_DT) FROM TIM_DELEGACION WHERE DELEGACIONTC_ID = 885) AND DATEADD(DD,-1,GETDATE()) AND B.BOLETIN_ORIGEN_ID IS NULL) AS A 
go

/*** Query    (0000016 milisegundos) ******CONTEXT@    1,AP_CMDELEGACION#107651,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:20,739,D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor,164;****************************************/
SELECT COUNT(DISTINCT E.EMPLEADOTC_ID) AS FORMACION_PRL_PEND FROM TIM_EMPLEADO E INNER JOIN TIM_CONTRATO C ON E.EMPLEADOTC_ID = C.EMPLEADOTC_ID INNER JOIN TIM_FORMACIONCURSOS X ON X.EMPLEADOTC_CD = E.EMPLEADOTC_CD AND X.TIPO_CODIGO_CD = E.TIPO_CODIGO_CD WHERE C.DELEGACIONTC_ID = 885 AND C.INICIO_DT < GETDATE() AND ISNULL(C.ISANULATED_FL,0) = 0 AND (C.FIN_REAL_DT >= CONVERT(datetime, CONVERT(date, GETDATE())) OR C.FIN_REAL_DT IS NULL) AND X.TIPOCURSO_DS = 'PRL/Online' AND (X.EXPIRACION_DT > GETDATE() OR X.EXPIRACION_DT IS NULL) AND ISNULL(X.ESTADOCURSO_DS,'') NOT IN ('Completado','Finalizado')
go

/*** Query    (0000016 milisegundos) ******CONTEXT@    1,AP_CMDELEGACION#107651,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:20,754,D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor,164;****************************************/
SELECT COUNT(DISTINCT E.EMPLEADOTC_ID) AS FORMACION_PRL_PROX_CADUCIDAD FROM TIM_EMPLEADO E INNER JOIN TIM_CONTRATO C ON E.EMPLEADOTC_ID = C.EMPLEADOTC_ID INNER JOIN TIM_FORMACIONCURSOS X ON X.EMPLEADOTC_CD = E.EMPLEADOTC_CD AND X.TIPO_CODIGO_CD = E.TIPO_CODIGO_CD WHERE C.DELEGACIONTC_ID = 885  AND C.INICIO_DT < GETDATE() AND ISNULL(C.ISANULATED_FL,0) = 0 AND (C.FIN_REAL_DT >= CONVERT(datetime, CONVERT(date, GETDATE())) OR C.FIN_REAL_DT IS NULL) AND X.TIPOCURSO_DS = 'PRL/Online' AND DATEDIFF(DAY,CAST(GETDATE() AS DATE),X.EXPIRACION_DT) < 60
go

/*** Query    (0000015 milisegundos) ******CONTEXT@    1,AP_CMDELEGACION#107651,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:20,779,D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor,164;****************************************/
SELECT COUNT(DISTINCT E.EMPLEADOTC_ID) AS FORMACION_PRL_METAL FROM TIM_CONTRATO C INNER JOIN TIM_EMPLEADO E ON E.EMPLEADOTC_ID = C.EMPLEADOTC_ID WHERE C.DELEGACIONTC_ID = 885 AND C.ISANULATED_FL = 0 AND (C.FIN_REAL_DT IS NULL OR C.FIN_REAL_DT >=GETDATE()) AND EXISTS(SELECT 1 FROM TIM_CLIENTETC CL WHERE CL.CLIENTETC_ID = C.CLIENTETC_ID  AND CL.SECTOR_ACTIVIDAD_ID IN (SELECT SA.SECTOR_ACTIVIDAD_ID FROM TIM_SECTOR_ACTIVIDAD SA WHERE SA.FORMACION_METAL_FL = 1)) AND EXISTS(SELECT 1 FROM TIM_DOMICILIOCLIENTETC DC WHERE DC.DOMICILIOCLIENTETC_ID = C.DOMICILIOCLIENTETC_ID AND DC.EXENTO_METAL_DOC_ID IS NULL) AND NOT EXISTS(SELECT 1 FROM TIM_DOCUMENTACION_EMPLEADO DE WHERE DE.EMPLEADOTC_ID = E.EMPLEADOTC_ID AND DE.TIPODOCUMENTO_ID IN (SELECT TD.TIPODOCUMENTO_ID FROM TIM_TIPODOCUMENTO TD WHERE TD.FORMACION_METAL_FL = 1)AND DE.ESTADO_CD IN ('VALIDADO_OCR', 'VALIDADO_DELEGACION') AND (DE.EXPIRACION_DT IS NULL OR EXPIRACION_DT > C.INICIO_DT))
go

/*** Query    (0000125 milisegundos) ******CONTEXT@    1,AP_CMDELEGACION#107651,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:20,903,D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor,164;****************************************/
SELECT SUM(X.ACTIVO_FL) AS ACTIVOS_FD,SUM(X.INACTIVO_FL) AS INACTIVOS_FD FROM ( SELECT CASE WHEN EXISTS(SELECT 1 FROM TIM_CONTRATO C     WHERE C.EMPLEADOTC_ID = E.EMPLEADOTC_ID     AND C.ISANULATED_FL = 0    AND C.DELEGACIONTC_ID = 885    AND C.SUPUESTO_DS = 'IFJ'    AND C.FIN_REAL_DT IS NULL ) THEN 1 ELSE 0 END AS ACTIVO_FL, CASE WHEN EXISTS (SELECT 1 FROM ACP_CONTRATO XX_ACP_CONTRATO INNER JOIN ACP_EMPLEADO_PETICION XX_ACP_EMPLEADO_PETICION ON XX_ACP_EMPLEADO_PETICION.MOTIVOSFIN_ACP_ID = 6 AND XX_ACP_EMPLEADO_PETICION.EMPLEADO_PETICIONACP_ID = XX_ACP_CONTRATO.EMPLEADO_PETICIONACP_ID WHERE XX_ACP_CONTRATO.CONTRATOTC_ID = ( SELECT XX_TIM_CONTRATO.CONTRATOTC_ID FROM TIM_CONTRATO XX_TIM_CONTRATO     CROSS APPLY (SELECT TOP 1 C.CONTRATOTC_ID FROM TIM_CONTRATO C WHERE C.EMPLEADOTC_ID = E.EMPLEADOTC_ID       AND C.ISANULATED_FL = 0 AND C.FIN_REAL_DT IS NOT NULL       ORDER BY C.FIN_REAL_DT DESC) XX_ULTIMO_CONTRATO    WHERE XX_ULTIMO_CONTRATO.CONTRATOTC_ID = XX_TIM_CONTRATO.CONTRATOTC_ID AND XX_TIM_CONTRATO.SUPUESTO_DS = 'IFJ'       AND XX_TIM_CONTRATO.DELEGACIONTC_ID = 885)       AND XX_ACP_CONTRATO.ESTADO_CD <> 'ANULADO' AND NOT EXISTS(SELECT 1 FROM TIM_CONTRATO C WHERE          C.EMPLEADOTC_ID = E.EMPLEADOTC_ID AND C.ISANULATED_FL = 0          AND C.FIN_REAL_DT IS NULL) ) THEN 1 ELSE 0 END AS INACTIVO_FL FROM TIM_EMPLEADO E WHERE EXISTS(SELECT 1 FROM TIM_DELEGACIONESEMPLEADOS DE WHERE DE.EMPLEADOTC_ID = E.EMPLEADOTC_ID AND DE.DELEGACIONTC_ID = 885) ) X
go

/*** Query    (0000016 milisegundos) ******CONTEXT@    1,AP_CMDELEGACION#107651,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:20,906,D:\ADSP\SERVICES\ADECCO4U\Program\TimeCapture\funciones\f_resultadositavisosole.cor,520;****************************************/
