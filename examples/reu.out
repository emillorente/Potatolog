/*** Query    (0000000 milisegundos) ******CONTEXT@    1,AP_CMDELEGACION#107651,CORE_GETTOOLBAR,ejavier.llorente,06/07/26 10:18:20,600,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT I.INFORME_ID,I.INFORME_CD,I.INFORME_DS,I.CARPETA_ID,I.PUBLICO_FL,I.EXECTYPE_CD,I.SHOW_AP_FL,I.REPORT_DRAW_DS,I.PAGING_SIZE_NM,I.DESARROLLO_FL,I.EDITABLE_FL,I.ADMINISTRADOR_FL,I.WITHOUT_LINK_FL,I.GENERAR_VIEW_FL,I.ERROR_VIEW_FL,I.CONTENT_FL,I.ALTA_USR,I.ALTA_DT,I.MOD_USR,I.MOD_DT,(SELECT X.CARPETA_DS FROM INF_CARPETA X WHERE X.CARPETA_ID = I.CARPETA_ID) AS CARPETA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = I.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = I.MOD_USR) AS MOD_DS, ( CASE 	WHEN (I.DESARROLLO_FL = 1) THEN 0 	WHEN (I.EDITABLE_FL = 0) THEN 0 	ELSE 1 END ) AS EDIT_IMPORT_FL,I.INFORME_DS FROM INF_INFORME I  WHERE I.SHOW_AP_FL = 1 AND ( I.ALTA_USR = 1569014 OR 	I.INFORME_ID IN (-1) OR 	I.PUBLICO_FL IS NOT NULL AND I.PUBLICO_FL = 1 ) AND I.INFORME_ID IN ( SELECT X.INFORME_ID FROM INF_CONCEPTO X WHERE X.CONCEPTO_CD = 'DOSSIERPROJECT' ) ORDER BY I.INFORME_DS 
go

