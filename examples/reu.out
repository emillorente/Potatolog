SELECT I.INFORME_ID,I.INFORME_CD,I.INFORME_DS,I.CARPETA_ID,I.PUBLICO_FL,I.EXECTYPE_CD,I.SHOW_AP_FL,I.REPORT_DRAW_DS,I.PAGING_SIZE_NM,I.DESARROLLO_FL,I.EDITABLE_FL,I.ADMINISTRADOR_FL,I.WITHOUT_LINK_FL,I.GENERAR_VIEW_FL,I.ERROR_VIEW_FL,I.CONTENT_FL,I.ALTA_USR,I.ALTA_DT,I.MOD_USR,I.MOD_DT,(SELECT X.CARPETA_DS FROM INF_CARPETA X WHERE X.CARPETA_ID = I.CARPETA_ID) AS CARPETA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = I.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = I.MOD_USR) AS MOD_DS, ( CASE 	WHEN (I.DESARROLLO_FL = 1) THEN 0 	WHEN (I.EDITABLE_FL = 0) THEN 0 	ELSE 1 END ) AS EDIT_IMPORT_FL,I.INFORME_DS FROM INF_INFORME I  WHERE I.INFORME_ID IN ( SELECT X.INFORME_ID FROM INF_AUTORIZACION X WHERE 	( ( X.AUTHORIZED_USR IS NOT NULL AND X.AUTHORIZED_USR = 1569014 ) OR ( X.AUTHORIZED_ROL_CD IS NOT NULL AND X.AUTHORIZED_ROL_CD = 'A@930' ) ) ) AND I.ALTA_USR <> 1569014 ORDER BY I.INFORME_DS 
go

