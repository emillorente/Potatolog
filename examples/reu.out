INSERT INTO CTO_LOGPROFILE(LOG_CD,LOG_DT,USR_CD,CLASE_CD,OBJ_ID,PROC_CD,TIME_NM,VM_CD,SERVICE_DS,COMPUTERNAME_DS,OBJECTS_NM) VALUES (N'POST',{ts '2026-07-06 10:18:08.788'},1569014,N'AP_SOLICITUDHORARIO',N'105509',N'CORE_EXPANDOBJ',0,N'1',N'ADECCO4U',N'WSESDEV0013',2) 
