SELECT P.PANEL_ID,P.PANEL_CD,P.PANEL_DS,P.TIPO_CD,P.FILENAME_DS,P.WDG_TYPE_CD,P.DESARROLLO_FL,P.EDITABLE_FL,P.ALTA_USR,P.ALTA_DT,P.MOD_USR,P.MOD_DT, ( CASE P.DESARROLLO_FL 	WHEN 1 THEN 'XPRT_' + P.PANEL_CD 	ELSE P.PANEL_CD END ) AS PANEL_XPRT_CD,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = P.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = P.MOD_USR) AS MOD_DS, ( CASE 	WHEN (P.DESARROLLO_FL = 1) THEN 0 	WHEN (P.EDITABLE_FL = 0) THEN 0 	ELSE 1 END ) AS EDIT_IMPORT_FL,P.PANEL_DS FROM PAN_PANEL P  WHERE P.PANEL_ID IN ( SELECT X.PANEL_ID FROM PAN_PANEL_AP X WHERE 	X.ACCESSPOINT_ID = 105509 ) ORDER BY P.PANEL_DS 
go

/*** Query    (0000047 milisegundos) ******CONTEXT@    1,AP_SOLICITUDHORARIO#105509,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:08,862,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT S.SOLICITUDHORARIO_ID,S.SOLICITUDHORARIO_DS,S.SOLICITUDHORARIO_CD,S.EMPLEADO_PETICIONACP_ID,S.ESTADO_CD,S.ESTADO_DT,S.SOLICITUDHORARIO_OLD_ID,S.PETICIONACP_ID,S.ALTA_USR,S.ALTA_DT,S.MOD_USR,S.MOD_DT,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = S.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = S.MOD_USR) AS MOD_DS, (SELECT (SUM(HO.HORAS_TOTALES_NM)) FROM ACP_HORARIO HO WHERE HO.SOLICITUDHORARIO_ID = S.SOLICITUDHORARIO_ID AND HO.APPLY_FL = 1) AS HORAS_SEMANALES_NM, (SELECT (UPPER(ISNULL(X.NOMBRE_DS,'') + ' ' + ISNULL(X.APELLIDOS_DS,''))) FROM TIM_EMPLEADO X WHERE X.EMPLEADOTC_ID = (SELECT Y.EMPLEADOTC_ID FROM ACP_EMPLEADO_PETICION Y WHERE Y.EMPLEADO_PETICIONACP_ID = S.EMPLEADO_PETICIONACP_ID)) AS NOMBRE_EMPLEADO_DS,(SELECT X.INICIO_DT FROM ACP_EMPLEADO_PETICION X WHERE X.EMPLEADO_PETICIONACP_ID = S.EMPLEADO_PETICIONACP_ID) AS INICIO_DT, (SELECT PR.TIPO_VALIDACION_CD FROM ACP_PROYECTO PR WHERE PR.PROYECTOACP_ID = 	(SELECT PT.PROYECTOACP_ID FROM ACP_PETICIONACP PT WHERE PT.PETICIONACP_ID = S.PETICIONACP_ID) ) AS TIPO_VALIDACION_CD,(SELECT X.FIN_PREVISTA_DT FROM ACP_EMPLEADO_PETICION X WHERE X.EMPLEADO_PETICIONACP_ID = S.EMPLEADO_PETICIONACP_ID) AS FIN_PREVISTA_DT, (SELECT X.EMPLEADOTC_CD FROM TIM_EMPLEADO X WHERE X.EMPLEADOTC_ID = (SELECT Y.EMPLEADOTC_ID FROM ACP_EMPLEADO_PETICION Y WHERE Y.EMPLEADO_PETICIONACP_ID = S.EMPLEADO_PETICIONACP_ID)) AS REGISTRO_EMPLEADO_CD,(SELECT X.SEQ_PETICION_CD FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = S.PETICIONACP_ID) AS SEQ_PETICION_CD,(SELECT X.ORDEN_GRUPO_NM FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = S.PETICIONACP_ID) AS ORDEN_GRUPO_NM, (SELECT X.DELEGACIONTC_ID FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = S.PETICIONACP_ID) AS DELEGACIONTC_ID,S.SOLICITUDHORARIO_DS FROM ACP_SOLICITUDHORARIO S  WHERE S.PETICIONACP_ID IN (select XX.PETICIONACP_ID from ACP_PETICIONACP XX where 		( 			'DELEGACION_TC_ACP' IN ('CLIENTE_ACP', 'CLIENTE_BYPEDIDO_ACP', 'CLIENTE_TC_ACP') 			AND XX.ORGANIZACIONRS_ID = NULL 			AND XX.ORG_HOJA_ID IN (3239,1564744,602412,1565968,1508151,1565969,2818,14748,1991,1992,3543,3544,3541,3542 ) 		) 		OR 		( 			'DELEGACION_TC_ACP' IN ('ACP_DELEGACION', 'DELEGACION_TC_ACP') 			AND XX.DELEGACIONTC_ID = NULL 			 		) 		OR 		( 			'DELEGACION_TC_ACP' IN ('ACP_SUPER', 'ACP_ADMINISTRADOR') 			AND XX.ORG_HOJA_ID IN (3239,1564744,602412,1565968,1508151,1565969,2818,14748,1991,1992,3543,3544,3541,3542) 			AND XX.OFICINAACP_ID IN (SELECT OFI.OFICINAACP_ID FROM ACP_OFICINA OFI WHERE OFI.DELEGACIONTC_ID = 885) 		) ) ORDER BY S.SOLICITUDHORARIO_ID DESC 
go

