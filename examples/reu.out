/*** Query    (0000015 milisegundos) ******CONTEXT@    1,SESSIONADECCO#CORE,ONBEGINVM,ejavier.llorente,06/07/26 10:18:01,944,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT O.ORGANIZACIONRS_ID,O.ORGANIZACIONRS_CD,O.ORGANIZACIONRS_DS,O.FATHER_CD,O.ORGANIZACION_ID,O.ESTRUCTURARS_ID,O.RESPONSABLE_CD,O.ORGROOT_ID,O.BOSS_ID,O.ACTIVO_FL,O.NODO_ID,O.INACTIVO_ID,O.TREE_CD,O.DIAGRAMA_XML,O.COMENTARIO_DS,O.ALTA_USR,O.ALTA_DT,O.MOD_USR,O.MOD_DT, ( SELECT X.ORGANIZACIONRS_DS FROM RS_ORGANIZACION X WHERE 	X.ORGANIZACIONRS_ID = O.FATHER_CD ) AS FATHER_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = O.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = O.MOD_USR) AS MOD_DS,(SELECT X.ESTRUCTURARS_DS FROM RS_ESTRUCTURA X WHERE X.ESTRUCTURARS_ID = O.ESTRUCTURARS_ID) AS ESTRUCTURARS_DS,(SELECT X.ORGANIZACION_DS FROM AD_ORGANIZACION X WHERE X.ORGANIZACION_ID = O.ORGANIZACION_ID) AS ORGANIZACION_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = O.RESPONSABLE_CD) AS RESPONSABLE_DS,(SELECT X.ORGANIZACIONRS_DS FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = O.ORGROOT_ID) AS ORGROOT_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = O.BOSS_ID) AS BOSS_DS,(SELECT X.NODO_DS FROM RS_NODOESTRUCTURA X WHERE X.NODO_ID = O.NODO_ID) AS NODO_DS,(SELECT X.NODO_CD + '-' + X.NODO_DS FROM RS_NODOESTRUCTURA X WHERE X.NODO_ID = O.NODO_ID) AS NODOCOMP_DS, ( SELECT X.NODO_ID FROM RS_ORGANIZACION X WHERE 	X.ORGANIZACIONRS_ID = O.FATHER_CD ) AS NODOFATHER_ID,(SELECT X.COMPLETO_FL FROM RS_ESTRUCTURA X WHERE X.ESTRUCTURARS_ID = O.ESTRUCTURARS_ID) AS COMPLETO_FL,(SELECT X.USR_MULTIPLE_FL FROM RS_ESTRUCTURA X WHERE X.ESTRUCTURARS_ID = O.ESTRUCTURARS_ID) AS USR_MULTIPLE_FL, dbo.getPathOrgRS(O.ORGANIZACIONRS_ID,1,0,'/') AS PATH_ORG_DS, ( SELECT X.ACTIVO_FL FROM RS_ORGANIZACION X WHERE 	X.ORGANIZACIONRS_ID = O.FATHER_CD ) AS ACTIVO_FATHER_FL,(SELECT X.ESTRICTO_FL FROM RS_ESTRUCTURA X WHERE X.ESTRUCTURARS_ID = O.ESTRUCTURARS_ID) AS ESTRICTO_FL,(SELECT X.NODO_CD FROM RS_NODOESTRUCTURA X WHERE X.NODO_ID = O.NODO_ID) AS NODO_CD,(SELECT X.ESTRUCTURARS_CD FROM RS_ESTRUCTURA X WHERE X.ESTRUCTURARS_ID = O.ESTRUCTURARS_ID) AS ESTRUCTURARS_CD,(SELECT X.LOGIN_DS FROM AD_USR X WHERE X.USR_CD = O.BOSS_ID) AS LOGIN_BOSS_DS,(SELECT X.LOGIN_DS FROM AD_USR X WHERE X.USR_CD = O.RESPONSABLE_CD) AS LOGIN_RESP_DS,(SELECT X.ORGANIZACIONRS_CD FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = O.INACTIVO_ID) AS INACTIVO_CD, O.FATHER_CD AS FATHER_ID,O.FILE_LOGO_DS,O.GRUPO_ID,O.RANQUEO_FL,O.GUARDIAS_FL,O.BUYADECCO_FL,O.LIST_TIPOPETICION_DS,O.FILE_MANUAL_DS,O.ACCESO_ESIGN_FL,O.ACCESO_FACTELEC_FL,O.ESTRUCTURAADECCO_FL,O.CLIENTETC_ID,O.DOMICILIOCLIENTETC_ID,O.AUTOPEDIDO_FL,O.CLIENTE_PORTAL_FL,(SELECT X.GRUPO_DS FROM AD_GRUPOSECTORIAL X WHERE X.GRUPO_ID = O.GRUPO_ID) AS GRUPO_DS, ( SELECT X.NIF_CD FROM AD_ORGANIZACION X WHERE 	X.ORGANIZACION_ID = O.ORGANIZACION_ID ) AS CIF_CD, dbo.getPathOrgRS(O.ORGANIZACIONRS_ID,0,0,'<br/>') AS PATH_ACP_DS FROM RS_ORGANIZACION O  WHERE O.ESTRUCTURAADECCO_FL IN (0,1) AND NOT EXISTS( 	SELECT X.NODO_ID FROM RS_NODOESTRUCTURA X WHERE X.FATHER_ID = O.NODO_ID ) AND O.ORGANIZACIONRS_ID IN (SELECT OFI.ORGANIZACIONRS_ID FROM ACP_OFICINA OFI WHERE OFI.DELEGACIONTC_ID = 885) ORDER BY O.ORGANIZACIONRS_CD 
go

