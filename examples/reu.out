/*** Query    (0000000 milisegundos) ******CONTEXT@trg82FC,TRIGGER_INFORMES#B53294FC-A0C3-4862-A835-5A1C99303D18,CREATE_VIEW_RP,,06/07/26 09:57:45,604,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT I.INFORME_ID,I.INFORME_CD,I.INFORME_DS,I.CARPETA_ID,I.PUBLICO_FL,I.EXECTYPE_CD,I.SHOW_AP_FL,I.REPORT_DRAW_DS,I.PAGING_SIZE_NM,I.DESARROLLO_FL,I.EDITABLE_FL,I.ADMINISTRADOR_FL,I.WITHOUT_LINK_FL,I.GENERAR_VIEW_FL,I.ERROR_VIEW_FL,I.CONTENT_FL,I.ALTA_USR,I.ALTA_DT,I.MOD_USR,I.MOD_DT,(SELECT X.CARPETA_DS FROM INF_CARPETA X WHERE X.CARPETA_ID = I.CARPETA_ID) AS CARPETA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = I.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = I.MOD_USR) AS MOD_DS, ( CASE 	WHEN (I.DESARROLLO_FL = 1) THEN 0 	WHEN (I.EDITABLE_FL = 0) THEN 0 	ELSE 1 END ) AS EDIT_IMPORT_FL,I.INFORME_DS FROM INF_INFORME I  WHERE I.GENERAR_VIEW_FL = 1 AND I.ERROR_VIEW_FL = 0 ORDER BY I.INFORME_DS 
go

