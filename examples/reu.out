/*** Query    (0000000 milisegundos) ******CONTEXT@    1,AP_PRESENCIA#105505,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:06,077,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT P.PANEL_ID,P.PANEL_CD,P.PANEL_DS,P.TIPO_CD,P.FILENAME_DS,P.WDG_TYPE_CD,P.DESARROLLO_FL,P.EDITABLE_FL,P.ALTA_USR,P.ALTA_DT,P.MOD_USR,P.MOD_DT, ( CASE P.DESARROLLO_FL 	WHEN 1 THEN 'XPRT_' + P.PANEL_CD 	ELSE P.PANEL_CD END ) AS PANEL_XPRT_CD,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = P.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = P.MOD_USR) AS MOD_DS, ( CASE 	WHEN (P.DESARROLLO_FL = 1) THEN 0 	WHEN (P.EDITABLE_FL = 0) THEN 0 	ELSE 1 END ) AS EDIT_IMPORT_FL,P.PANEL_DS FROM PAN_PANEL P  WHERE P.PANEL_ID IN ( SELECT X.PANEL_ID FROM PAN_PANEL_AP X WHERE 	X.ACCESSPOINT_ID = 105505 ) ORDER BY P.PANEL_DS 
