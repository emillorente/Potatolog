SELECT R.ROLUSUARIO_ID,R.USR_CD,R.SC_ROL_CD,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = R.USR_CD) AS NAME_DS ,(CASE WHEN (SELECT X.SC_ROL_CD FROM AD_USR X WHERE X.USR_CD = R.USR_CD) = R.SC_ROL_CD THEN 1 ELSE 0 END) AS USER_SEL_FL  FROM B2T_ROL_USUARIO R  WHERE R.USR_CD = 1569014 
