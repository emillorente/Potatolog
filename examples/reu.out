/*** Query    (0000015 milisegundos) ******CONTEXT@    1,AP_PETICIONACP#105504,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:14,981,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT P.PANEL_ID,P.PANEL_CD,P.PANEL_DS,P.TIPO_CD,P.FILENAME_DS,P.WDG_TYPE_CD,P.DESARROLLO_FL,P.EDITABLE_FL,P.ALTA_USR,P.ALTA_DT,P.MOD_USR,P.MOD_DT, ( CASE P.DESARROLLO_FL 	WHEN 1 THEN 'XPRT_' + P.PANEL_CD 	ELSE P.PANEL_CD END ) AS PANEL_XPRT_CD,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = P.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = P.MOD_USR) AS MOD_DS, ( CASE 	WHEN (P.DESARROLLO_FL = 1) THEN 0 	WHEN (P.EDITABLE_FL = 0) THEN 0 	ELSE 1 END ) AS EDIT_IMPORT_FL,P.PANEL_DS FROM PAN_PANEL P  WHERE P.PANEL_ID IN ( SELECT X.PANEL_ID FROM PAN_PANEL_AP X WHERE 	X.ACCESSPOINT_ID = 105504 ) ORDER BY P.PANEL_DS 
go

/*** Query    (0000766 milisegundos) ******CONTEXT@    1,AP_PETICIONACP#105504,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:15,759,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT P.PETICIONACP_ID,P.PETICION_DT,P.VALIDACION_DT,P.CODIGO_CD,P.ASIGNACION_DT,P.PERSONA_CONTACTO_DS,P.PERSONA_SUSTITUIR_DS,P.CANTIDAD_NM,P.REGISTRO_SUSTITUIDO_DS,P.COMENTARIOS_DS,P.INICIO_DT,P.FIN_PREVISTA_DT,P.TIPO_PETICIONACP_CD,P.ESPECIALIDADACP_ID,P.PROYECTOACP_ID,P.OFICINAACP_ID,P.TIPO_SUSTITUCION_CD,P.JORNADAACP_ID,P.TIPO_JORNADAACP_CD,P.JUSTIFICACION_ID,P.ESTADO_CD,P.ESTADO_DT,P.TURNO_ROTATIVO_CD,P.MAINFILE_ID,P.TIPO_MOTIVO_CD,P.SS_DS,P.EMPRESAACP_ID,P.TIPO_REGISTRO_CD,P.DIAS_TRABAJO_DS,P.PETICIONACP_OLD_ID,P.PETICIONACP_ORIGEN_ID,P.PETICIONARIO_USR,P.SEQ_PETICION_CD,P.JUSTIFICACION_LIBRE_DS,P.ORGANIZACIONRS_ID,P.ORG_HOJA_ID,P.CECO_ID,P.GUARDIA_FL,P.OFICINA_GUARDIA_DS,P.FUNCIONES_DS,P.FUNCIONES_CLI_DS,P.HORAS_HORESP_NM,P.HORESP_DS,P.DIAS_HORESP_DS,P.INCIDENCIAORIGEN_ID,P.CODEXTERNO_CD,P.SUBTIPO_PETICIONACP_ID,P.NACIMIENTO_DT,P.NUMHIJOS_CD,P.MOTIVO_NO_CUBIERTO_CD,P.ESTRUCTURAADECCO_FL,P.TIPO_REG_COTIZ_CD,P.MUJER_SUBREPRES_FL,P.RELACIONLABORALESPECIAL_ID,P.IMPRESION_FECHA_FIN_FL,P.PERFIL_DS,P.ROPA_TRABAJO_DS,P.COMEDOR_PROPIO_EMPRESA_FL,P.NUM_REGISTRO_CD,P.OBS_CONDICIONES_ESPECIALES_DS,P.CONTROL_PRESENCIA_FL,P.PROPUESTA_ACTIVA_FL,P.PUB_MISION_INTERNET_FL,P.DOMICILIOCLIENTETC_ID,P.SUBCUENTADOMICILIOTC_ID,P.NUM_PEDIDO_CLIENTE_CD,P.RIESGOS_ESPECIFICOS_DS,P.MEDIDAS_SEGURIDAD_DS,P.MISION_NM,P.REVISION_NM,P.GRUPOMISION_NM,P.CONDICIONES_ESPECIALES_DS,P.FEST_SABADO_INI_DT,P.FEST_DOMINGO_INI_DT,P.FEST_NOCTURN_INI_DT,P.FEST_NOCTURN_FIN_DT,P.FEST_SABADO_FIN_DT,P.FEST_DOMINGO_FIN_DT,P.PERIODO_BOLETIN_CD,P.PERIODO_FACTURACION_CD,P.AGRUPACION_FACTURA_ID,P.DIR_GEOREGIONIDEN_ID,P.DIR_TOWN_DS,P.DIR_TYPESTREET_CD,P.DIR_TYPEADDRESSNUMBER_CD,P.DIR_ADDRESSNUMBER_DS,P.DIR_STAIR_DS,P.DIR_FLOOR_DS,P.DIR_DOOR_DS,P.DIR_ZIPCODE_DS,P.DIR_TLF_DS,P.DIR_DEPARTAMENTO_DS,P.DIR_STREET_DS,P.TIPOCONTRATO_ID,P.TIPOCOMPLETOPARCIAL_CD,P.REGLASBONIFICACION_ID,P.CONVENIO_ID,P.TIPOPERIODOJORNADA_CD,P.BONIFICADO_FL,P.CONVENIO6MESES_FL,P.PROP_COLLECTIVEBARGAINNAME_DS,P.PROP_WEEKLYHOURSQUANTITY_NM,P.PROP_DAYHOURSQUANTITY_NM,P.PROP_WAGE_NM,P.PROP_WAGEPERMONTH_NM,P.PROP_TARIFFRESULT_NM,P.PROP_TARIFFPERMONTH_NM,P.PROP_TARIFFPERMONTH7_NM,P.PROP_QUOTATIONGROUPID_CD,P.PROP_EPIGRAPHID_CD,P.PROP_COLLECTIVEBARGAINIDEN_NM,P.PROP_HOURSQUANTITY_NM,P.PROP_WORKINGDAYS_NM,P.PROP_QUOTATIONREGIMEID_CD,P.PROP_PROPOSALNUMBER_CD,P.PROP_ISSUINGDATE_DT,P.PROP_COLLBARGAINCATPROFNAME_DS,P.GRUPOCOTIZACION_ID,P.PROP_ASOCIADA_FL,P.COEFICIENTE_NM,P.PROP_EPIGRAPH_DS,P.HORASTOTALES_NM,P.PROP_HASBONUSMATERNITY_FL,P.PROP_HASSPECIALCONTRACT_FL,P.PROP_PAGAS_NM,P.PROP_PROPUESTAACP_ID,P.PROP_PROFESSIONALCATEGORYID_CD,P.ORDERLINE_NM,P.IDEXTERNO_HORARIO_NM,P.PROP_HOURSPERMONTH_NM,P.PROP_TARIFFPERDAY_NM,P.PROP_TARIFFRESULT7_NM,P.PROP_WAGEPERDAY_NM,P.NOTASGASTOS_FL,P.PROPUESTOSINSERT_FL,P.ATTACHEDIDEN_NM,P.FILE_PREVRIES_ID,P.PROP_PROPOSALDETAILNUMBER_ID,P.GRUPO_PROFESIONAL_ID,P.RENOVACION_FL,P.DIRECCION_EMAIL_DS,P.BEFORE_ET_FL,P.CARGA_OLE_FL,P.HORARIO_DS,P.HORARIO_MANANA_INI_NM,P.HORARIO_MANANA_FIN_NM,P.HORARIO_TARDE_FIN_NM,P.HORARIO_TARDE_INI_NM,P.VALID_ENVIO_OLE_FL,P.HORESP_REGULAR_FL,P.CENTROTRABAJO_ID,P.SUSTITUCION_FL,P.SALARIO_NM,P.PAGAS_NM,P.PLAZO_SELECCION_DT,P.PLAZO_DOC_DT,P.CONTRATO_MERCANTIL_ID,P.CONVENIO_CONTRATO_ID,P.NAME_SUSTITUCION_DS,P.CONSULTOR_USR_CD,P.CONSULTOR_SC_ID,P.PENDIENTE_DT,P.COMPLETADO_DT,P.SMARTCITY_ID,P.CODIGOROL_CD,P.GESTIONAR_DT,P.GESTIONAR_USR,P.FATHER_ID,P.ORDEN_GRUPO_NM,P.INSERT_DT,P.GUID_ORDER_INFO_CD,P.INFO_MAP_DS,P.CLIENTETC_ID,P.DELEGACIONTC_ID,P.URL_INFO_DS,P.PRL_EXCELOMETRO_ID,P.PRL_VIGILANCIA_CD,P.PRL_VIGILANCIA_DS,P.PRL_EPI_CD,P.PRL_EPI_DS,P.PRL_FORMACION_CD,P.PRL_FORMACION_DS,P.PRL_COMENTARIOS_DS,P.PRL_WOW_CD,P.PRL_PLAN_SEG_CD,P.PRL_COORDINADOR_CD,P.PRL_ESPECIFICO_CD,P.PRL_CURSOTPC_CD,P.PRL_ATTACHED_ID,P.VAL_REG_USR,P.VAL_REG_DT,P.VAL_TERR_USR,P.VAL_TERR_DT,P.PROP_PERFIL_PROFA_ID,P.PROP_SECTOR_ID,P.HORARIO_LLAMAMIENTO_NM,P.CURSO_PRL_ID,P.FORMACION_PRL_PRESENCIAL_FL,P.SUBGRUPOTC_ID,P.CURSO_PRL_DS,P.ALTA_USR,P.ALTA_DT,P.MOD_USR,P.MOD_DT, (SELECT TOP 1 X.TIPOPETICIONNOCUBIERTA_ID FROM ACP_NOCUBIERTO_PETICION X WHERE X.PETICIONACP_ID = P.PETICIONACP_ID AND X.PETICIONACP_HIJO_ID IS NULL) AS TIPOPETICIONNOCUBIERTA_ID, (SELECT MAX(EP.FIN_REAL_DT) FROM ACP_EMPLEADO_PETICION EP WHERE EP.PETICIONACP_ID = P.PETICIONACP_ID) AS FIN_REAL_DT,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = P.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = P.MOD_USR) AS MOD_DS,(SELECT X.NOMBRE_DS FROM ACP_ESPECIALIDAD X WHERE X.ESPECIALIDADACP_ID = P.ESPECIALIDADACP_ID) AS ESPECIALIDADACP_DS,(SELECT X.NOMBRE_DS FROM ACP_PROYECTO X WHERE X.PROYECTOACP_ID = P.PROYECTOACP_ID) AS PROYECTOACP_DS,(SELECT X.NOMBRE_DS FROM ACP_OFICINA X WHERE X.OFICINAACP_ID = P.OFICINAACP_ID) AS OFICINAACP_DS,(SELECT X.TIPO_SUSTITUCION_DS FROM ACP_TIPO_SUSTITUCIONACP X WHERE X.TIPO_SUSTITUCION_ID = P.TIPO_SUSTITUCION_CD) AS TIPO_SUSTITUCION_DS,(SELECT X.INICIO_DT FROM ACP_PROYECTO X WHERE X.PROYECTOACP_ID = P.PROYECTOACP_ID) AS INICIO_PROY_DT,(SELECT X.FIN_DT FROM ACP_PROYECTO X WHERE X.PROYECTOACP_ID = P.PROYECTOACP_ID) AS FIN_PROY_DT,(SELECT X.TIPO_VALIDACION_CD FROM ACP_PROYECTO X WHERE X.PROYECTOACP_ID = P.PROYECTOACP_ID) AS TIPO_VALIDACION_PROY_CD,(SELECT X.FILE_CD FROM DOC_FILE X WHERE X.FILE_ID = P.MAINFILE_ID) AS MAINFILE_DS,(SELECT X.DESCRIPCION_DS FROM ACP_JORNADA X WHERE X.JORNADAACP_ID = P.JORNADAACP_ID) AS JORNADAACP_DS, dbo.GetHorasTotalesPedido(P.PETICIONACP_ID) AS HORAS_ESTIMADAS_NM,(SELECT X.NOMBRE_DS FROM ACP_EMPRESA X WHERE X.EMPRESAACP_ID = P.EMPRESAACP_ID) AS NOMBRE_DS,(SELECT X.EMAIL_DS FROM AD_USR X WHERE X.USR_CD = P.ALTA_USR) AS ALTA_EMAIL_DS, (SELECT X.CIF_CD FROM TIM_CLIENTETC X WHERE X.CLIENTETC_ID = P.CLIENTETC_ID) AS CIF_CD, (SELECT CASE WHEN O.CODIGO_NM IS NOT NULL THEN O.CODIGO_NM + ' - ' ELSE '' END + O.NOMBRE_DS FROM ACP_OFICINA O WHERE O.OFICINAACP_ID = P.OFICINAACP_ID) AS COMBINADO_OFICINA_DS, (SELECT DL.DELEGACIONTC_CD + ' - ' + DL.NOMBRE_DS FROM TIM_DELEGACION DL WHERE DL.DELEGACIONTC_ID = P.DELEGACIONTC_ID) AS COMBINADO_DELEGACION_DS, (SELECT US.NAME_DS FROM AD_USR US WHERE US.USR_CD = P.PETICIONARIO_USR) AS PETICIONARIO_DS, ( CASE 	WHEN (SELECT COUNT(*) FROM ( 			SELECT FIN_PRORROGA_DT FROM ACP_EMPLEADO_PETICION EP WHERE EP.PETICIONACP_ID = P.PETICIONACP_ID 			GROUP BY FIN_PRORROGA_DT) AS D) = 1 	THEN 		(SELECT MAX(FIN_PRORROGA_DT) FROM ACP_EMPLEADO_PETICION EP WHERE EP.PETICIONACP_ID = P.PETICIONACP_ID) 	ELSE NULL END ) AS FIN_PRORROGA_DT,(SELECT X.CODIGO_CD FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = P.PETICIONACP_OLD_ID) AS CODIGO_OLD_CD,(SELECT X.CANTIDAD_NM FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = P.PETICIONACP_OLD_ID) AS CANTIDAD_OLD_NM,(SELECT X.PERSONA_CONTACTO_DS FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = P.PETICIONACP_OLD_ID) AS PERSONA_CONTACTO_OLD_DS,(SELECT X.INICIO_DT FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = P.PETICIONACP_OLD_ID) AS INICIO_OLD_DT,(SELECT X.FIN_PREVISTA_DT FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = P.PETICIONACP_OLD_ID) AS FIN_PREVISTA_OLD_DT,(SELECT (SELECT MAX(EP.FIN_REAL_DT) FROM ACP_EMPLEADO_PETICION EP WHERE EP.PETICIONACP_ID = X.PETICIONACP_ID) FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = P.PETICIONACP_OLD_ID) AS FIN_REAL_OLD_DT,(SELECT (SELECT Y.NOMBRE_DS FROM ACP_OFICINA Y WHERE Y.OFICINAACP_ID = X.OFICINAACP_ID) FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = P.PETICIONACP_OLD_ID) AS OFICINAACP_OLD_DS, (SELECT PT.SEQ_PETICION_CD FROM ACP_PETICIONACP PT WHERE PT.PETICIONACP_ID = P.PETICIONACP_OLD_ID) AS SEQ_PETICION_OLD_CD,(SELECT X.NOMBRE_OLE_DS FROM ACP_JUSTIFICACION X WHERE X.JUSTIFICACION_ID = P.JUSTIFICACION_ID) AS NOMBRE_OLE_DS,(SELECT X.TEXTOLIBRE_FL FROM ACP_JUSTIFICACION X WHERE X.JUSTIFICACION_ID = P.JUSTIFICACION_ID) AS TEXTOLIBRE_FL,(SELECT X.CODIGO_NM FROM ACP_OFICINA X WHERE X.OFICINAACP_ID = P.OFICINAACP_ID) AS OFICINAACP_CD,(SELECT X.ORGANIZACIONRS_DS FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = P.ORGANIZACIONRS_ID) AS ORGANIZACIONRS_DS,(SELECT dbo.getPathOrgRS(X.ORGANIZACIONRS_ID,0,0,'<br/>') FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = P.ORG_HOJA_ID) AS PATH_ACP_DS,(SELECT (SELECT dbo.getPathOrgRS(Y.ORGANIZACIONRS_ID,0,0,'<br/>') FROM RS_ORGANIZACION Y WHERE Y.ORGANIZACIONRS_ID = X.ORG_HOJA_ID) FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = P.PETICIONACP_OLD_ID) AS PATH_ACP_OLD_DS,(SELECT X.ORGANIZACIONRS_DS FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = P.ORG_HOJA_ID) AS ORG_HOJA_DS,(SELECT X.ORGANIZACIONRS_CD FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = P.ORG_HOJA_ID) AS ORG_HOJA_CD,(SELECT X.CECO_DS FROM ACP_CECO X WHERE X.CECO_ID = P.CECO_ID) AS CECO_DS, (SELECT CASE WHEN ORGRS.ORGANIZACIONRS_CD IS NOT NULL THEN ORGRS.ORGANIZACIONRS_CD +' - ' ELSE '' END + ORGRS.ORGANIZACIONRS_DS FROM RS_ORGANIZACION ORGRS WHERE ORGRS.ORGANIZACIONRS_ID = P.ORG_HOJA_ID) AS COMBINADO_ORG_HOJA_DS,(SELECT X.VALID_CLIENTE_FL FROM ACP_TIPO_PETICIONACP X WHERE X.TIPO_PETICIONACP_ID = P.TIPO_PETICIONACP_CD) AS VALID_CLIENTE_FL, (SELECT UPPER(SUBSTRING ( CASE 	WHEN P.ESTADO_CD IN ('VALIDAR_REG', 'VALIDAR_TERR', 'PENDIENTE') THEN ( SELECT RTRIM(', '+E.NOMBRE_DS + ' '+ ISNULL(E.APELLIDOS_DS, '')) FROM TIM_EMPLEADO E WHERE E.EMPLEADOTC_ID IN (SELECT PR.EMPLEADOTC_ID FROM ACP_PROPUESTOS PR WHERE PR.PETICIONACP_ID = P.PETICIONACP_ID) FOR XML PATH ('')) 	ELSE ( 	SELECT RTRIM(', '+E.NOMBRE_DS + ' '+ ISNULL(E.APELLIDOS_DS, '')) FROM TIM_EMPLEADO E WHERE E.EMPLEADOTC_ID IN (SELECT EP.EMPLEADOTC_ID FROM ACP_EMPLEADO_PETICION EP WHERE EP.PETICIONACP_ID = P.PETICIONACP_ID) FOR XML PATH ('') ) END, 2, 8000))) AS LIST_PERSONAL_DS,(SELECT X.TIPO_PETICIONACP_DS FROM ACP_TIPO_PETICIONACP X WHERE X.TIPO_PETICIONACP_ID = P.TIPO_PETICIONACP_CD) AS TIPO_PETICIONACP_DS,(SELECT X.ENVIO_OLE_FL FROM ACP_TIPO_PETICIONACP X WHERE X.TIPO_PETICIONACP_ID = P.TIPO_PETICIONACP_CD) AS ENVIO_OLE_FL,(SELECT X.PRESENCIAS_FL FROM ACP_TIPO_PETICIONACP X WHERE X.TIPO_PETICIONACP_ID = P.TIPO_PETICIONACP_CD) AS PRESENCIAS_FL,(SELECT X.SUBTIPO_DS FROM ACP_TIPO_PETICIONACP X WHERE X.TIPO_PETICIONACP_ID = P.SUBTIPO_PETICIONACP_ID) AS SUBTIPO_PETICIONACP_DS, (SELECT Y.TIPOPETICIONNOCUBIERTA_DS FROM ACP_TIPOPETICIONNOCUBIERTA Y WHERE Y.TIPOPETICIONNOCUBIERTA_ID = (SELECT TOP 1 X.TIPOPETICIONNOCUBIERTA_ID FROM ACP_NOCUBIERTO_PETICION X WHERE X.PETICIONACP_ID = P.PETICIONACP_ID AND X.PETICIONACP_HIJO_ID IS NULL) ) AS TIPOPETICIONNOCUBIERTA_DS,(SELECT X.RELACIONLABORALESPECIAL_DS FROM EST_RELACIONLABORALESPECIAL X WHERE X.RELACIONLABORALESPECIAL_ID = P.RELACIONLABORALESPECIAL_ID) AS RELACIONLABORALESPECIAL_DS,(SELECT X.RELACIONLABORALESPECIAL_CD FROM EST_RELACIONLABORALESPECIAL X WHERE X.RELACIONLABORALESPECIAL_ID = P.RELACIONLABORALESPECIAL_ID) AS RELACIONLABORALESPECIAL_CD, (SELECT A.AGRUPACION_FACTURA_DS FROM TIM_AGRUPACION_FACTURA A WHERE A.AGRUPACION_FACTURA_ID = P.AGRUPACION_FACTURA_ID) AS AGRUPACION_FACTURA_DS, dbo.getTimDireccionDs(P.DOMICILIOCLIENTETC_ID) AS DOMICILIOCLIENTE_DS, (SELECT X.CODEXTERNO_CD FROM TIM_DOMICILIOCLIENTETC X WHERE X.DOMICILIOCLIENTETC_ID = P.DOMICILIOCLIENTETC_ID) AS DOMICILIOCODEXT_CD, (SELECT X.CODEXTERNO_CD FROM TIM_SUBCUENTADOMICILIOTC X WHERE X.SUBCUENTADOMICILIOTC_ID = P.SUBCUENTADOMICILIOTC_ID) AS SUBCUENTACODEXT_CD,(SELECT X.NOMBRE_DS FROM ACP_TIPOCONTRATO X WHERE X.TIPOCONTRATO_ID = P.TIPOCONTRATO_ID) AS TIPOCONTRATO_DS,(SELECT X.HORAS_NM FROM ACP_TIPOCONTRATO X WHERE X.TIPOCONTRATO_ID = P.TIPOCONTRATO_ID) AS TIPOCONTR_HORAS_NM,(SELECT X.TIEMPO_COMPLETO_FL FROM ACP_TIPOCONTRATO X WHERE X.TIPOCONTRATO_ID = P.TIPOCONTRATO_ID) AS TIEMPO_COMPLETO_FL,(SELECT X.GRUPOCOTIZACION_DS FROM ACP_GRUPOCOTIZACION X WHERE X.GRUPOCOTIZACION_ID = P.GRUPOCOTIZACION_ID) AS GRUPOCOTIZACION_DS, (SELECT X.CODEXTERNO_CD FROM TIM_GRUPO_PROFESIONAL X WHERE X.GRUPO_PROFESIONAL_ID = P.GRUPO_PROFESIONAL_ID) AS CODEXT_ESPECIALIDAD_CD, (SELECT X.SUBCUENTADOMICILIOTC_dS FROM TIM_SUBCUENTADOMICILIOTC X WHERE X.SUBCUENTADOMICILIOTC_ID = P.SUBCUENTADOMICILIOTC_ID) AS SUBCUENTADOMICILIOTC_DS, (SELECT A.CODEXTERNO_CD FROM TIM_AGRUPACION_FACTURA A WHERE A.AGRUPACION_FACTURA_ID = P.AGRUPACION_FACTURA_ID) AS AGRUPACION_FACTURA_CODEX_CD, (SELECT X.GRUPO_PROFESIONAL_DS FROM TIM_GRUPO_PROFESIONAL X WHERE X.GRUPO_PROFESIONAL_ID = P.GRUPO_PROFESIONAL_ID) AS GRUPO_PROFESIONAL_DS, (SELECT X.GEOCODE_FL FROM TIM_CENTROTRABAJO X WHERE X.CENTROTRABAJO_ID = P.CENTROTRABAJO_ID) AS GEOCODE_FL, (CASE P.ESTADO_CD WHEN 'VALIDAR_REG' THEN 'Validar por el superior' WHEN 'VALIDAR_TERR' THEN 'Validar por el superior del superior' WHEN 'PENDIENTE' THEN 'Pendiente' WHEN 'CURSO' THEN 'En curso' WHEN 'COMPLETADO' THEN 'Completado' WHEN 'VALIDAR_CLIENTE' THEN 'Candidatura presentada' WHEN 'FINALIZAR_DELEG' THEN 'Finalizar por la delegación' WHEN 'CONTRATADO' THEN 'Contratado' WHEN 'FINALIZADO' THEN 'Finalizado' WHEN 'RECHAZADO' THEN 'Rechazado' WHEN 'ANULADO' THEN 'Anulado' ELSE '' END) AS ESTADO_ORDER_DS,(SELECT X.CONTRATO_DS FROM ACP_CONTRATO_MERCANTIL X WHERE X.CONTRATO_ID = P.CONTRATO_MERCANTIL_ID) AS CONTRATO_MERCANTIL_DS,(SELECT X.CONVENIO_DS FROM ACP_CONVENIO_CONTRATO X WHERE X.CONVENIO_ID = P.CONVENIO_CONTRATO_ID) AS CONVENIO_CONTRATO_DS, (SELECT X.NOMBRE_DS + ' ' + X.APELLIDOS_DS FROM AD_USR X WHERE X.USR_CD = P.CONSULTOR_USR_CD) AS CONSULTOR_USR_DS, CASE WHEN EXISTS(SELECT 1 FROM ACP_NOTIFICACIONUSUARIO A INNER JOIN DOC_COMMENT C ON A.CONCEPTOBASE_CD= 'COMMENTDOCUMENT' AND C.COMMENT_ID = A.CONCEPTOBASE_ID WHERE C.CONCEPTOBASE_ID = P.PETICIONACP_ID AND A.USR_CD = 1569014 AND A.VISTO_DT IS NULL ) THEN 1 ELSE 0 END AS REVIEWCOMMENT_FL, (SELECT X.RENOVACION_FL FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = P.PETICIONACP_OLD_ID) AS RENOVACION_OLD_FL, (SELECT XX.NOMBRE_DS FROM ACP_ESPECIALIDAD XX WHERE XX.ESPECIALIDADACP_ID = (SELECT X.ESPECIALIDADACP_ID FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = P.PETICIONACP_OLD_ID)) AS ESPECIALIDADACP_OLD_DS, dbo.GetDescHorarioIrregular(P.PETICIONACP_ID,P.TIPO_JORNADAACP_CD) AS HORARIO_IRREGULAR_DS, ((SELECT COUNT(*) FROM ACP_EMPLEADO_PETICION E WHERE E.PETICIONACP_ID = P.PETICIONACP_ID AND E.EMPLEADOTC_ID IS NOT NULL) + ISNULL((SELECT SUM(H.PLAZAS_NOCUBIERTAS_NM) FROM ACP_NOCUBIERTO_PETICION H WHERE H.PETICIONACP_ID = P.PETICIONACP_ID) ,0)) AS CANTIDAD_NOPDTE_NM, ISNULL((SELECT SUM(H.PLAZAS_NOCUBIERTAS_NM) FROM ACP_NOCUBIERTO_PETICION H WHERE H.PETICIONACP_ID = P.PETICIONACP_ID AND H.PETICIONACP_HIJO_ID IS NOT NULL) ,0) AS CANTIDAD_CUBGRP_NM,(SELECT X.STAFFING_FL FROM ACP_TIPO_PETICIONACP X WHERE X.TIPO_PETICIONACP_ID = P.TIPO_PETICIONACP_CD) AS STAFFING_FL, (SELECT X.CLIENTETC_DS FROM TIM_CLIENTETC X WHERE X.CLIENTETC_ID = P.CLIENTETC_ID) AS CLIENTETC_DS, (SELECT X.DELEGACIONTC_CD FROM TIM_DELEGACION X WHERE X.DELEGACIONTC_ID = P.DELEGACIONTC_ID) AS DELEGACIONTC_CD,(SELECT X.CLIENTE_PORTAL_FL FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = P.ORGANIZACIONRS_ID) AS CLIENTE_PORTAL_FL, (SELECT OLDP.JUSTIFICACION_LIBRE_DS FROM ACP_PETICIONACP OLDP WHERE OLDP.PETICIONACP_ID = P.PETICIONACP_OLD_ID) AS JUSTIFICACIONACP_OLD_DS, ISNULL((SELECT X.DESCRIPCION_DS FROM ACP_JORNADA X WHERE X.JORNADAACP_ID = P.JORNADAACP_ID),P.HORESP_DS) AS JORNADAEMAIL_DS, ISNULL((SELECT X.DESCRIPCION_DS FROM ACP_JORNADA X WHERE X.JORNADAACP_ID = (SELECT OLDP.JORNADAACP_ID FROM ACP_PETICIONACP OLDP WHERE OLDP.PETICIONACP_ID = P.PETICIONACP_OLD_ID )),(SELECT OLDP.HORESP_DS FROM ACP_PETICIONACP OLDP WHERE OLDP.PETICIONACP_ID = P.PETICIONACP_OLD_ID )) AS JORNADAEMAIL_OLD_DS, (CASE WHEN ORDEN_GRUPO_NM IS NULL THEN 'Todos' ELSE 'Grupo ' + CAST(ORDEN_GRUPO_NM AS VARCHAR) END) AS PETICION_SUBGRUPO_DS, P.ESPECIALIDADACP_ID AS CATEGORIA_BYADECCO_ID, P.GRUPO_PROFESIONAL_ID AS CATEGORIA_ID, (SELECT S.SUBGRUPOTC_DS FROM TIM_SUBGRUPOTC S WHERE S.SUBGRUPOTC_ID = P.SUBGRUPOTC_ID) AS SUBGRUPO_TC_DS, ( CASE 	WHEN P.CURSO_PRL_ID IS NOT NULL THEN P.CURSO_PRL_DS 	WHEN ISNULL(P.FORMACION_PRL_PRESENCIAL_FL,0) = 1 THEN 'Formación PRL Presencial' 	ELSE '' END ) AS CURSO_PRL_SHOW_DS FROM ACP_PETICIONACP P  WHERE P.FATHER_ID IN (SELECT PP.FATHER_ID FROM ACP_PETICIONACP PP 	WHERE PP.ESTADO_CD NOT IN ('ANULADO','ANULADO_POR_CLIENTE','FINALIZADO','RECHAZADO') 	AND ( ( 'DELEGACION_TC_ACP' IN ('CLIENTE_ACP', 'CLIENTE_BYPEDIDO_ACP', 'CLIENTE_TC_ACP') AND PP.ORGANIZACIONRS_ID = NULL AND PP.ESTRUCTURAADECCO_FL = 0 ) OR ( 'DELEGACION_TC_ACP' IN ('ACP_SUPER', 'ACP_ADMINISTRADOR') AND PP.ESTRUCTURAADECCO_FL = 0 AND PP.DELEGACIONTC_ID = 885 ) OR ( 'DELEGACION_TC_ACP' IN ('ACP_DELEGACION', 'DELEGACION_TC_ACP') AND PP.DELEGACIONTC_ID = 885 ) )  	AND ( ( 0 = 1 AND PP.ORGANIZACIONRS_ID = NULL AND PP.ORG_HOJA_ID IN (3239,1564744,602412,1565968,1508151,1565969,2818,14748,1991,1992,3543,3544,3541,3542 ) ) OR ( 1 = 1 AND PP.DELEGACIONTC_ID = 885 ) ) ) ORDER BY P.ALTA_DT DESC,P.SEQ_PETICION_CD DESC,P.ORDEN_GRUPO_NM ASC 
go

/*** Query    (0000000 milisegundos) ******CONTEXT@    1,AP_PETICIONACP#105504,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:15,963,D:\ADSP\SERVICES\ADECCO4U\Program\SesionAdecco\funciones\f_sessionadecco.cor,2021;****************************************/
SELECT D.DELEGACIONTC_ID,D.NOMBRE_DS,D.TIPO_DELEGACION_CD,D.MES_CERRADO_DT,D.DELEGACIONTC_CD,D.DELEGACION_DR_ID,D.DELEGACION_DR_CD,D.IS_STAFFING_FL,D.CONTACTO_EMPLEADO2_ID,D.TIPONIVELACCESO_CD,D.ISGGCC_FL,D.ADECCOHOLDING_CD,D.SINCRO_PROFA_FL,D.TELEFONO1_CD,D.TELEFONO2_CD,D.FAX_CD,D.CODE,D.INTEGRACIONOLE_FL,D.BEGINNINGDATE_DT,D.ENDINGDATE_DT,D.ALTA_USR,D.ALTA_DT,D.MOD_USR,D.MOD_DT, (D.DELEGACIONTC_CD + ' - ' + D.NOMBRE_DS) AS COMBINADO_DELEGACION_DS,(SELECT X.TIPONIVELACCESO_DS FROM TIM_TIPONIVELACCESO X WHERE X.TIPONIVELACCESO_CD = D.TIPONIVELACCESO_CD) AS TIPONIVELACCESO_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = D.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = D.MOD_USR) AS MOD_DS, (CASE WHEN EXISTS(SELECT 1 FROM ACP_ADECCO_HOLDING X WHERE X.ADECCOHOLDING_CD = D.ADECCOHOLDING_CD AND X.OS_FL = 1) THEN 1 ELSE 0 END) AS IS_OS_FL,'0' FROM TIM_DELEGACION D WHERE D.DELEGACIONTC_ID = 885 
go

/*** Query    (0000000 milisegundos) ******CONTEXT@    1,,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:15,989,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\centro\ctoDefISAPI.cor,600;****************************************/
INSERT INTO CTO_LOGPROFILE(LOG_CD,LOG_DT,USR_CD,CLASE_CD,OBJ_ID,PROC_CD,TIME_NM,VM_CD,SERVICE_DS,COMPUTERNAME_DS,OBJECTS_NM) VALUES (N'POST',{ts '2026-07-06 10:18:15.985'},1569014,N'AP_PETICIONACP',N'105504',N'CORE_DOFILTER',1031,N'1',N'ADECCO4U',N'WSESDEV0013',156) 
go

/*** Query    (0000000 milisegundos) ******CONTEXT@    1,AP_PETICIONACP#105504,SEARCHITEMS,ejavier.llorente,06/07/26 10:18:17,089,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT P.TIPO_PETICIONACP_ID,P.TIPO_PETICIONACP_DS,P.PRESENCIAS_FL,P.ENVIO_OLE_FL,P.VALID_CLIENTE_FL,P.PERMITE_GUARDIAS_FL,P.TIPO_FATHER_ID,P.SUBTIPO_DS,P.STAFFING_FL,P.ACTIVO_FL,P.ESPECIAL_FL,P.DESDE_DT,P.HASTA_DT,P.FD_OBLIGATORIO_FL FROM ACP_TIPO_PETICIONACP P WHERE (P.TIPO_FATHER_ID IS NULL OR P.TIPO_FATHER_ID = P.TIPO_PETICIONACP_ID) AND P.ESPECIAL_FL = 0 AND ( ('DELEGACION_TC_ACP' = 'CLIENTE_ACP' AND (SELECT X.LIST_TIPOPETICION_DS FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = NULL) LIKE '%¦'+P.TIPO_PETICIONACP_ID+'¦%') OR ('DELEGACION_TC_ACP' <> 'CLIENTE_ACP') ) 
go

/*** Query    (0000031 milisegundos) ******CONTEXT@    1,AP_PETICIONACP#105504,SEARCHITEMS,ejavier.llorente,06/07/26 10:18:17,120,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT O.OFICINAACP_ID,O.NOMBRE_DS,O.CODIGO_NM,O.ESTADO_CD,O.ESTADO_DT,O.MAINFILE_ID,O.PAISACP_ID,O.COMUNIDADAUTONOMAACP_ID,O.PROVINCIAACP_ID,O.LOCALIDADACP_ID,O.ORGANIZACIONRS_ID,O.DOMICILIOCLIENTETC_ID,O.EMPRESAACP_ID,O.DELEGACIONTC_ID,O.ALTA_USR,O.ALTA_DT,O.MOD_USR,O.MOD_DT,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = O.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = O.MOD_USR) AS MOD_DS,(SELECT X.FILE_CD FROM DOC_FILE X WHERE X.FILE_ID = O.MAINFILE_ID) AS MAINFILE_DS,(SELECT X.NOMBRE_DS FROM TIM_DELEGACION X WHERE X.DELEGACIONTC_ID = O.DELEGACIONTC_ID) AS DELEGACION_DS,(SELECT X.DELEGACIONTC_CD FROM TIM_DELEGACION X WHERE X.DELEGACIONTC_ID = O.DELEGACIONTC_ID) AS DELEGACIONTC_CD,(SELECT X.LOCALIDADACP_DS FROM ACP_LOCALIDADACP X WHERE X.LOCALIDADACP_ID = O.LOCALIDADACP_ID) AS LOCALIDADACP_DS,(SELECT X.PAISACP_DS FROM ACP_PAISACP X WHERE X.PAISACP_ID = O.PAISACP_ID) AS PAISACP_DS,(SELECT X.PROVINCIAACP_DS FROM ACP_PROVINCIAACP X WHERE X.PROVINCIAACP_ID = O.PROVINCIAACP_ID) AS PROVINCIAACP_DS,(SELECT X.COMUNIDADAUTONOMAACP_DS FROM ACP_COMUNIDADAUTONOMAACP X WHERE X.COMUNIDADAUTONOMAACP_ID = O.COMUNIDADAUTONOMAACP_ID) AS COMUNIDADAUTONOMAACP_DS, (CASE WHEN O.CODIGO_NM IS NOT NULL THEN O.CODIGO_NM + ' - ' ELSE '' END + O.NOMBRE_DS) AS COMBINADO_DS, (SELECT dbo.getPathOrgRSWithCode(X.ORGANIZACIONRS_ID,0,0,'<br/>') FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = O.ORGANIZACIONRS_ID) AS PATH_ACP_DS,(SELECT X.ORGANIZACIONRS_DS FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = O.ORGANIZACIONRS_ID) AS ORGANIZACIONRS_DS,(SELECT X.ORGROOT_ID FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = O.ORGANIZACIONRS_ID) AS ORGROOT_ID,(SELECT (SELECT Y.ORGANIZACIONRS_DS FROM RS_ORGANIZACION Y WHERE Y.ORGANIZACIONRS_ID = X.ORGROOT_ID) FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = O.ORGANIZACIONRS_ID) AS ORGROOT_DS, (SELECT X.CODEXTERNO_CD FROM TIM_DOMICILIOCLIENTETC X WHERE X.DOMICILIOCLIENTETC_ID = O.DOMICILIOCLIENTETC_ID) AS DOMICILIOCLIENTETC_CD, dbo.getTimDireccionDs(O.DOMICILIOCLIENTETC_ID) AS DOMICILIOCLIENTETC_DS,(SELECT X.NOMBRE_DS FROM ACP_EMPRESA X WHERE X.EMPRESAACP_ID = O.EMPRESAACP_ID) AS EMPRESAACP_DS,(SELECT X.TREE_CD FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = O.ORGANIZACIONRS_ID) AS TREE_CD,(SELECT X.ORGANIZACIONRS_CD FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = O.ORGANIZACIONRS_ID) AS ORGANIZACIONRS_CD, (SELECT X.CLIENTE_PORTAL_FL FROM RS_ORGANIZACION X WHERE X.ORGANIZACIONRS_ID = (SELECT Y.ORGROOT_ID FROM RS_ORGANIZACION Y WHERE Y.ORGANIZACIONRS_ID = O.ORGANIZACIONRS_ID)) AS CLIENTE_PORTAL_FL,CAST(O.CODIGO_NM as VARCHAR(20)) + ' - ' + O.NOMBRE_DS FROM ACP_OFICINA O  WHERE O.ORGANIZACIONRS_ID = NULL AND O.ESTADO_CD IN ('ACTIVA') AND O.ESTADO_CD IN ('ACTIVA') AND ( ('DELEGACION_TC_ACP' IN ('CLIENTE_ACP', 'CLIENTE_BYPEDIDO_ACP', 'CLIENTE_TC_ACP')) OR ( 'DELEGACION_TC_ACP' IN ('ACP_SUPER', 'ACP_ADMINISTRADOR', 'ACP_DELEGACION', 'DELEGACION_TC_ACP') AND O.DELEGACIONTC_ID = 885 ) OR ( 'DELEGACION_TC_ACP' IN ('DISTRICT_MANAGER','CONSULTOR_SC') AND O.DELEGACIONTC_ID IN (885) AND (NULL IS NULL OR O.DELEGACIONTC_ID = NULL) ) ) ORDER BY O.CODIGO_NM 
go

