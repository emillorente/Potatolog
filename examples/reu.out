INSERT INTO CTO_LOGPROFILE(LOG_CD,LOG_DT,USR_CD,CLASE_CD,OBJ_ID,PROC_CD,TIME_NM,VM_CD,SERVICE_DS,COMPUTERNAME_DS,OBJECTS_NM) VALUES (N'POST',{ts '2026-07-06 10:18:17.129'},1569014,N'AP_PETICIONACP',N'105504',N'SEARCHITEMS',47,N'1',N'ADECCO4U',N'WSESDEV0013',41) 
go

/*** Query    (0000000 milisegundos) ******CONTEXT@trg8AC4,TRIGGER_AUTOUPDATESERVICE#C50FD507-AEB2-4881-9E4E-1010C4FF4E32,AUTO_UPDATE_MODEL,,06/07/26 10:18:20,227,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT SS.SUBIDAVERSIONESSERVIDORES_ID,SS.ESTADO_CD,SS.ESTADO_DT,SS.SUBIDAVERSIONES_ID,SS.COMPUTERNAME_DS,SS.INFO_DS,SS.ALTA_USR,SS.ALTA_DT,SS.MOD_USR,SS.MOD_DT,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = SS.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = SS.MOD_USR) AS MOD_DS FROM UPD_SUBIDAVERSIONESSERVIDORES SS INNER JOIN UPD_SUBIDAVERSIONES S ON S.SUBIDAVERSIONES_ID = SS.SUBIDAVERSIONES_ID  WHERE SS.ESTADO_CD = 'PENDIENTE' AND SS.COMPUTERNAME_DS = 'WSESDEV0013' AND S.PROGRAMACION_DT < GETDATE() 
go

