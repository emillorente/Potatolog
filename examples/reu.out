SELECT U.USR_CD,U.NAME_DS,U.NOMBRE_DS,U.APELLIDOS_DS,U.EMPLEADO_CD,U.ORGANIZACION_ID,U.CARGO_DS,U.FOTO_DS,U.COMENTARIO_DS,U.LOGIN_DS,U.PWD_CD,U.LANGUAGE,U.CONEXIONES_NM,U.REEINTENTOS_NM,U.ULTIMA_DT,U.REEINTENTOS_DT,U.UUID_CD,U.ALTA_DT,U.ACTIVE_FL,U.INACTIVE_DT,U.ALTAUSER_DT,U.B2TUSER_FL,U.CHANGEPWD_DT,U.MUSTCHANGEPWD_FL,U.PWDEXPIRED_FL,U.SECURITY_CD,U.MOD_USR,U.MOD_DT,U.DIRECCION_DS,U.EMAIL_DS,U.TELEFONO_NM,U.EXTENSION_NM,U.MOVIL_NM,U.FAX_NM,U.POBLACION_DS,U.PROVINCIA_DS,U.POSTAL_CD,U.ACCESO_DT,U.ACCESO_USR,U.EMAIL2_DS,U.TELEFONO2_NM,U.NIF_CD,U.PAIS_CD,U.OFICINA_ID,U.SEXO_CD,U.ROL_CD,U.SC_ROL_CD,U.SMTP_SERVER_DS,U.SMTP_SSL_FL,U.SMTP_PORT_NM,U.SMTP_AUTH_CD,U.MAIL_SERVER_TYPE_CD,U.IMAP_SERVER_DS,U.IMAP_SSL_FL,U.IMAP_PORT_NM,U.IMAP_LOGIN_DS,U.IMAP_PWD_CD,U.USERMAIL_LOGIN_DS,U.USERMAIL_PWD_CD,U.EMAIL_PWD_CD,U.TOKEN_CD, U.TOKEN_VALIDITY_DT,U.TOKEN_PWD_CD,U.SIDAD_CD,U.LOGIN_CD,U.OAUTH_ACCESS_TOKEN_CD,U.OAUTH_ACCESS_TOKEN_DT,U.OAUTH_REFRESH_TOKEN_CD,(SELECT X.ROL_DS FROM AD_ROL X WHERE X.ROL_CD = U.ROL_CD),(SELECT X.PRIV_CD FROM AD_ROL X WHERE X.ROL_CD = U.ROL_CD),(SELECT X.PRIV_DS FROM AD_PRIV X WHERE X.PRIV_CD = (SELECT X.PRIV_CD FROM AD_ROL X WHERE X.ROL_CD = U.ROL_CD)),(SELECT X.PROFILE_CD FROM AD_ROL X WHERE X.ROL_CD = U.ROL_CD) ,(SELECT X.PROFILE_DS FROM AD_USRPROFILE X WHERE X.PROFILE_CD = (SELECT X.PROFILE_CD FROM AD_ROL X WHERE X.ROL_CD = U.ROL_CD)),(SELECT XX.ORGANIZACION_DS FROM AD_ORGANIZACION XX WHERE XX.ORGANIZACION_ID = U.ORGANIZACION_ID) AS ORGANIZACION_DS,U.NAME_DS ,(SELECT X.BOSS_ID FROM AD_ORGANIZACION X WHERE X.ORGANIZACION_ID = U.ORGANIZACION_ID),(SELECT X.ORGANIZACION_DS FROM AD_ORGANIZACION X WHERE X.ORGANIZACION_ID = U.OFICINA_ID) ,(SELECT I.UUID_CD FROM AD_IMAGEN I WHERE I.CONCEPTOBASE_CD ='PERSONA' AND I.CONCEPTOBASE_ID = U.USR_CD) AS UUIDIMAGEN_CD ,U.ACUERDO_NACIONAL_FL,U.LINEANEGOCIO_APLICADAS_DS,U.GGCC_FL,U.COLLEAGUE_CD,U.TIPO_DOCUMENTO_CD,U.ISESIGNADMIN_FL,U.TIPO_USUARIO_CD,U.APROBADOR_PROFA_FL,U.APROBADOR_ADRG_FL,U.PRICING_MANAGER_FL,U.MODIFICACION_DATOS_BANCARIOS_FL,U.GESTION_AMT_FL, (CASE WHEN EXISTS (SELECT 1 FROM TIM_ACCESOUSUARIODELEGACION X WHERE X.USR_CD = U.USR_CD AND (X.INICIO_DT IS NULL OR X.INICIO_DT <= GETDATE()) AND (X.FIN_DT IS NULL OR X.FIN_DT >= GETDATE())) THEN 1 ELSE 0 END)  AS USUARIO_EXISTS_FL, (SELECT TOP 1 X.ALTA_DT FROM PRO_LOGDELEGDR X WHERE U.USR_CD = X.USR_CD AND X.CLASE_CD = 'DR' ORDER BY X.ALTA_DT ASC) AS FIRST_CHANG_DR_DT, (SELECT TOP 1 X.ALTA_DT FROM PRO_LOGDELEGDR X WHERE U.USR_CD = X.USR_CD AND X.CLASE_CD = 'DR' ORDER BY X.ALTA_DT DESC) AS LAST_CHANG_DR_DT, (SELECT TOP 1 X.ALTA_DT FROM PRO_LOGDELEGDR X WHERE U.USR_CD = X.USR_CD AND X.CLASE_CD = 'DD' ORDER BY X.ALTA_DT DESC) AS LAST_CHANG_DE_DT, (SELECT TOP 1 X.ALTA_DT FROM PRO_LOGDELEGDR X WHERE U.USR_CD = X.USR_CD AND X.CLASE_CD = 'DD' ORDER BY X.ALTA_DT ASC) AS FIRST_CHANG_DEL_DT, (SELECT COUNT(X.CLASE_CD) FROM PRO_LOGDELEGDR X WHERE U.USR_CD = X.USR_CD AND X.CLASE_CD = 'DD') AS CHANG_DEL_NM, (SELECT COUNT(X.CLASE_CD) FROM PRO_LOGDELEGDR X WHERE U.USR_CD = X.USR_CD AND X.CLASE_CD = 'DR') AS CHANG_DR_NM FROM AD_USR U WHERE U.LOGIN_DS = 'ejavier.llorente' AND ACTIVE_FL = 'S' ORDER BY U.APELLIDOS_DS
go

