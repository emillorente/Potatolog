/*** Query    (0000016 milisegundos) ******CONTEXT@    1,AP_SOLICITUDMOVILIDAD#105508,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:07,677,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT P.PANEL_ID,P.PANEL_CD,P.PANEL_DS,P.TIPO_CD,P.FILENAME_DS,P.WDG_TYPE_CD,P.DESARROLLO_FL,P.EDITABLE_FL,P.ALTA_USR,P.ALTA_DT,P.MOD_USR,P.MOD_DT, ( CASE P.DESARROLLO_FL 	WHEN 1 THEN 'XPRT_' + P.PANEL_CD 	ELSE P.PANEL_CD END ) AS PANEL_XPRT_CD,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = P.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = P.MOD_USR) AS MOD_DS, ( CASE 	WHEN (P.DESARROLLO_FL = 1) THEN 0 	WHEN (P.EDITABLE_FL = 0) THEN 0 	ELSE 1 END ) AS EDIT_IMPORT_FL,P.PANEL_DS FROM PAN_PANEL P  WHERE P.PANEL_ID IN ( SELECT X.PANEL_ID FROM PAN_PANEL_AP X WHERE 	X.ACCESSPOINT_ID = 105508 ) ORDER BY P.PANEL_DS 
go

/*** Query    (0000046 milisegundos) ******CONTEXT@    1,AP_SOLICITUDMOVILIDAD#105508,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:07,729,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT S.SOLICITUDMOVILIDAD_ID,S.SOLICITUDMOVILIDAD_DS,S.SOLICITUDMOVILIDAD_CD,S.INICIO_DT,S.FIN_DT,S.COMENTARIOS_DS,S.OFICINAACP_ID,S.ESTADO_CD,S.ESTADO_DT,S.EMPLEADO_PETICIONACP_ID,S.PETICIONACP_ID,S.ALTA_USR,S.ALTA_DT,S.MOD_USR,S.MOD_DT, (SELECT E.EMPLEADOTC_CD FROM TIM_EMPLEADO E WHERE E.EMPLEADOTC_ID IN (SELECT EP.EMPLEADOTC_ID FROM ACP_EMPLEADO_PETICION EP WHERE EP.EMPLEADO_PETICIONACP_ID = S.EMPLEADO_PETICIONACP_ID)) AS REGISTRO_CD,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = S.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = S.MOD_USR) AS MOD_DS,(SELECT (CASE WHEN X.CODIGO_NM IS NOT NULL THEN X.CODIGO_NM + ' - ' ELSE '' END + X.NOMBRE_DS) FROM ACP_OFICINA X WHERE X.OFICINAACP_ID = S.OFICINAACP_ID) AS OFICINAACP_DS, (SELECT (UPPER(ISNULL(X.NOMBRE_DS,'') + ' ' + ISNULL(X.APELLIDOS_DS,'') )) FROM TIM_EMPLEADO X WHERE X.EMPLEADOTC_ID = (SELECT Y.EMPLEADOTC_ID FROM ACP_EMPLEADO_PETICION Y WHERE Y.EMPLEADO_PETICIONACP_ID = S.EMPLEADO_PETICIONACP_ID)) AS NOMBRE_EMPLEADO_DS,(SELECT X.OFICINAACP_ID FROM ACP_EMPLEADO_PETICION X WHERE X.EMPLEADO_PETICIONACP_ID = S.EMPLEADO_PETICIONACP_ID) AS OFICINA_OLD_ID,(SELECT (SELECT O.CODIGO_NM + ' - ' + O.NOMBRE_DS FROM ACP_OFICINA O WHERE O.OFICINAACP_ID = X.OFICINAACP_ID) FROM ACP_EMPLEADO_PETICION X WHERE X.EMPLEADO_PETICIONACP_ID = S.EMPLEADO_PETICIONACP_ID) AS OFICINA_OLD_DS,(SELECT X.INICIO_DT FROM ACP_EMPLEADO_PETICION X WHERE X.EMPLEADO_PETICIONACP_ID = S.EMPLEADO_PETICIONACP_ID) AS INICIO_CONTRATO_DT,(SELECT X.FIN_PREVISTA_DT FROM ACP_EMPLEADO_PETICION X WHERE X.EMPLEADO_PETICIONACP_ID = S.EMPLEADO_PETICIONACP_ID) AS FIN_PREVISTA_DT,(SELECT X.INICIO_DT FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = S.PETICIONACP_ID) AS PET_INICIO_DT,(SELECT X.FIN_PREVISTA_DT FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = S.PETICIONACP_ID) AS PET_FIN_PREVISTA_DT, (SELECT PR.TIPO_VALIDACION_CD FROM ACP_PROYECTO PR WHERE PR.PROYECTOACP_ID = 	(SELECT PT.PROYECTOACP_ID FROM ACP_PETICIONACP PT WHERE PT.PETICIONACP_ID = S.PETICIONACP_ID) ) AS TIPO_VALIDACION_CD,(SELECT X.SEQ_PETICION_CD FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = S.PETICIONACP_ID) AS SEQ_PETICION_CD,(SELECT X.ORGANIZACIONRS_ID FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = S.PETICIONACP_ID) AS ORGANIZACIONRS_ID,(SELECT X.ORDEN_GRUPO_NM FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = S.PETICIONACP_ID) AS ORDEN_GRUPO_NM, (SELECT X.DELEGACIONTC_ID FROM ACP_PETICIONACP X WHERE X.PETICIONACP_ID = S.PETICIONACP_ID) AS DELEGACIONTC_ID,S.SOLICITUDMOVILIDAD_DS FROM ACP_SOLICITUDMOVILIDAD S  WHERE S.PETICIONACP_ID IN (select XX.PETICIONACP_ID from ACP_PETICIONACP XX where 		( 			'DELEGACION_TC_ACP' IN ('CLIENTE_ACP', 'CLIENTE_BYPEDIDO_ACP', 'CLIENTE_TC_ACP') 			AND XX.ORGANIZACIONRS_ID = NULL 			AND XX.ORG_HOJA_ID IN (3239,1564744,602412,1565968,1508151,1565969,2818,14748,1991,1992,3543,3544,3541,3542 ) 		) 		OR 		( 			'DELEGACION_TC_ACP' IN ('ACP_DELEGACION', 'DELEGACION_TC_ACP') 			AND XX.DELEGACIONTC_ID = NULL 			 		) 		OR 		( 			'DELEGACION_TC_ACP' IN ('ACP_SUPER', 'ACP_ADMINISTRADOR') 			AND XX.ORG_HOJA_ID IN (3239,1564744,602412,1565968,1508151,1565969,2818,14748,1991,1992,3543,3544,3541,3542) 			AND XX.OFICINAACP_ID IN (SELECT OFI.OFICINAACP_ID FROM ACP_OFICINA OFI WHERE OFI.DELEGACIONTC_ID = 885) 		) ) ORDER BY S.SOLICITUDMOVILIDAD_ID DESC 
go

/*** Query    (0000000 milisegundos) ******CONTEXT@    1,AP_SOLICITUDMOVILIDAD#105508,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:07,738,D:\ADSP\SERVICES\ADECCO4U\Program\SesionAdecco\funciones\f_sessionadecco.cor,2021;****************************************/
SELECT D.DELEGACIONTC_ID,D.NOMBRE_DS,D.TIPO_DELEGACION_CD,D.MES_CERRADO_DT,D.DELEGACIONTC_CD,D.DELEGACION_DR_ID,D.DELEGACION_DR_CD,D.IS_STAFFING_FL,D.CONTACTO_EMPLEADO2_ID,D.TIPONIVELACCESO_CD,D.ISGGCC_FL,D.ADECCOHOLDING_CD,D.SINCRO_PROFA_FL,D.TELEFONO1_CD,D.TELEFONO2_CD,D.FAX_CD,D.CODE,D.INTEGRACIONOLE_FL,D.BEGINNINGDATE_DT,D.ENDINGDATE_DT,D.ALTA_USR,D.ALTA_DT,D.MOD_USR,D.MOD_DT, (D.DELEGACIONTC_CD + ' - ' + D.NOMBRE_DS) AS COMBINADO_DELEGACION_DS,(SELECT X.TIPONIVELACCESO_DS FROM TIM_TIPONIVELACCESO X WHERE X.TIPONIVELACCESO_CD = D.TIPONIVELACCESO_CD) AS TIPONIVELACCESO_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = D.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = D.MOD_USR) AS MOD_DS, (CASE WHEN EXISTS(SELECT 1 FROM ACP_ADECCO_HOLDING X WHERE X.ADECCOHOLDING_CD = D.ADECCOHOLDING_CD AND X.OS_FL = 1) THEN 1 ELSE 0 END) AS IS_OS_FL,'0' FROM TIM_DELEGACION D WHERE D.DELEGACIONTC_ID = 885 
go

