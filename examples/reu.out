/*** Query    (0000094 milisegundos) ******CONTEXT@    1,AP_PRESENCIA#105505,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:06,172,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT C.CONFLICTOTC_ID,C.CONFLICTOTC_DS,C.CONFLICTOTC_CD,C.GESTIONADO_FL,C.CONTRATOTC_ID,C.DELEGACIONTC_ID,C.ALTA_USR,C.ALTA_DT,C.MOD_USR,C.MOD_DT,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = C.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = C.MOD_USR) AS MOD_DS, EM.NOMBRE_DS + ' ' + EM.APELLIDOS_DS AS NOMBRE_EMPLEADO_DS, EM.EMPLEADOTC_ID AS EMPLEADOTC_ID, CT.NUMERO_CONTRATO_CD AS NUMERO_CONTRATO_CD, CT.INICIO_DT AS INICIO_DT, CL.CLIENTETC_DS AS CLIENTETC_DS, CT.DESCRIPCION_HORARIO_DS AS DESCRIPCION_HORARIO_DS, EM.MOVIL_CD AS MOVIL_CD, EM.EMAIL_DS AS EMAIL_DS,C.CONFLICTOTC_DS, (CASE WHEN EXISTS(SELECT 1 FROM TIM_ALERTA X WHERE X.CONTRATOTC_ID = C.CONTRATOTC_ID AND (({ts '2026-07-06 10:18:06.078'} IS NOT NULL AND X.ALTA_DT >= CONVERT(datetime,CONVERT(date,{ts '2026-07-06 10:18:06.078'})) ) OR X.ALTA_DT >= CONVERT(datetime,CONVERT(date,NULL)))) THEN 1 ELSE 0 END) AS TIENE_ALERTA_FL, (SELECT COUNT(X.CONFLICTOTC_ID)+1 FROM TIM_CONFLICTOTC X WHERE X.CONTRATOTC_ID = C.CONTRATOTC_ID AND NOT EXISTS ( 	SELECT 1 FROM TIM_FICHAJE Y 	WHERE Y.CONTRATOTC_ID = X.CONTRATOTC_ID 	AND Y.JORNADA_DT = Convert(datetime,CONVERT(DATE,X.ALTA_DT)) 	AND EXISTS(SELECT 1 FROM TIM_DETALLE_FICHAJE Z WHERE Z.FICHAJE_ID = Y.FICHAJE_ID) ) AND X.CONFLICTOTC_ID <> C.CONFLICTOTC_ID AND(({ts '2026-07-06 10:18:06.078'} IS NOT NULL AND X.ALTA_DT = CONVERT(datetime,CONVERT(date,{ts '2026-07-06 10:18:06.078'})) ) OR (X.ALTA_DT >= CONVERT(datetime,CONVERT(date,NULL)) AND X.ALTA_DT <= CONVERT(datetime,CONVERT(date,NULL)))) ) AS DIAS_PENDIENTES_NM FROM TIM_CONFLICTOTC C INNER JOIN TIM_CONTRATO CT ON C.CONTRATOTC_ID = CT.CONTRATOTC_ID INNER JOIN TIM_DELEGACION DEL ON CT.DELEGACIONTC_ID = DEL.DELEGACIONTC_ID INNER JOIN TIM_EMPLEADO EM ON CT.EMPLEADOTC_ID = EM.EMPLEADOTC_ID INNER JOIN TIM_CLIENTETC CL ON CT.CLIENTETC_ID = CL.CLIENTETC_ID  WHERE C.DELEGACIONTC_ID = 885 AND EXISTS(SELECT 1 FROM TIM_DELEGACIONESDOMICILIOS Y WHERE Y.DOMICILIOCLIENTETC_ID = CT.DOMICILIOCLIENTETC_ID AND Y.DELEGACIONTC_ID = 885) AND CT.ISANULATED_FL <> 1 AND NOT EXISTS ( 	SELECT 1 FROM TIM_FICHAJE Y 	WHERE Y.CONTRATOTC_ID = C.CONTRATOTC_ID 	AND Y.JORNADA_DT = Convert(datetime,CONVERT(DATE,C.ALTA_DT)) 	AND EXISTS(SELECT 1 FROM TIM_DETALLE_FICHAJE X WHERE X.FICHAJE_ID = Y.FICHAJE_ID) ) AND NOT EXISTS(SELECT 1 FROM TIM_INCAPACIDADTEMPORALTC Y 	WHERE Y.CONTRATOTC_ID = C.CONTRATOTC_ID AND ISNULL(Y.ANULADA_FL,0) = 0 	AND C.ALTA_DT >= Y.INICIO_DT 	AND (C.ALTA_DT <=Y.FIN_DT OR Y.FIN_DT IS NULL)) AND NOT EXISTS(SELECT 1 FROM TIM_SUSPENSIONCONTRATOTC Y 	WHERE Y.CONTRATOTC_ID = C.CONTRATOTC_ID 	AND C.ALTA_DT >= Y.INICIO_DT 	AND (C.ALTA_DT <=Y.FIN_DT OR Y.FIN_DT IS NULL)) AND (CONVERT(DATE, C.ALTA_DT) <= CT.FIN_REAL_DT OR CT.FIN_REAL_DT IS NULL) AND ( ( 'D' = 'D' 	AND C.ALTA_DT BETWEEN 			CONVERT(datetime,CONVERT(DATE,{ts '2026-07-06 10:18:06.078'})) 			AND 	 			DATEADD(DD,1,CONVERT(datetime,CONVERT(DATE,{ts '2026-07-06 10:18:06.078'}))) 	AND EXISTS(SELECT 1 FROM TIM_HORARIOCONTRATOTC Z 				WHERE Z.CONTRATOTC_ID = C.CONTRATOTC_ID 	AND HORA_INI_CD < convert(char(5), {ts '2026-07-06 10:18:06.078'}, 108)) ) OR ( 'D' = 'P' 	AND C.ALTA_DT BETWEEN 			CONVERT(datetime,CONVERT(DATE,NULL)) 			AND 	 			DATEADD(DD,1,CONVERT(datetime,CONVERT(DATE,NULL))) ) ) AND CT.TURNO_ESPECIAL_FL <> 1 ORDER BY C.CONTRATOTC_ID 
go

/*** Query    (0000062 milisegundos) ******CONTEXT@    1,AP_PRESENCIA#105505,CORE_DOFILTER,ejavier.llorente,06/07/26 10:18:06,234,D:\ADSP\SERVICES\ADECCO4U\mesa80\corfiles\corfiles\tools\c_centroext.cor,1352;****************************************/
SELECT C.CONFLICTOTC_ID,C.CONFLICTOTC_DS,C.CONFLICTOTC_CD,C.GESTIONADO_FL,C.CONTRATOTC_ID,C.DELEGACIONTC_ID,C.ALTA_USR,C.ALTA_DT,C.MOD_USR,C.MOD_DT,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = C.ALTA_USR) AS ALTA_DS,(SELECT X.NAME_DS FROM AD_USR X WHERE X.USR_CD = C.MOD_USR) AS MOD_DS, EM.NOMBRE_DS + ' ' + EM.APELLIDOS_DS AS NOMBRE_EMPLEADO_DS, EM.EMPLEADOTC_ID AS EMPLEADOTC_ID, CT.NUMERO_CONTRATO_CD AS NUMERO_CONTRATO_CD, CT.INICIO_DT AS INICIO_DT, CL.CLIENTETC_DS AS CLIENTETC_DS, CT.DESCRIPCION_HORARIO_DS AS DESCRIPCION_HORARIO_DS, EM.MOVIL_CD AS MOVIL_CD, EM.EMAIL_DS AS EMAIL_DS,C.CONFLICTOTC_DS, (CASE WHEN EXISTS(SELECT 1 FROM TIM_ALERTA X WHERE X.CONTRATOTC_ID = C.CONTRATOTC_ID AND (({ts '2026-07-06 10:18:06.078'} IS NOT NULL AND X.ALTA_DT >= CONVERT(datetime,CONVERT(date,{ts '2026-07-06 10:18:06.078'})) ) OR X.ALTA_DT >= CONVERT(datetime,CONVERT(date,NULL)))) THEN 1 ELSE 0 END) AS TIENE_ALERTA_FL, (SELECT COUNT(X.CONFLICTOTC_ID)+1 FROM TIM_CONFLICTOTC X WHERE X.CONTRATOTC_ID = C.CONTRATOTC_ID AND NOT EXISTS ( 	SELECT 1 FROM TIM_FICHAJE Y 	WHERE Y.CONTRATOTC_ID = X.CONTRATOTC_ID 	AND Y.JORNADA_DT = Convert(datetime,CONVERT(DATE,X.ALTA_DT)) 	AND EXISTS(SELECT 1 FROM TIM_DETALLE_FICHAJE Z WHERE Z.FICHAJE_ID = Y.FICHAJE_ID) ) AND X.CONFLICTOTC_ID <> C.CONFLICTOTC_ID AND(({ts '2026-07-06 10:18:06.078'} IS NOT NULL AND X.ALTA_DT = CONVERT(datetime,CONVERT(date,{ts '2026-07-06 10:18:06.078'})) ) OR (X.ALTA_DT >= CONVERT(datetime,CONVERT(date,NULL)) AND X.ALTA_DT <= CONVERT(datetime,CONVERT(date,NULL)))) ) AS DIAS_PENDIENTES_NM FROM TIM_CONFLICTOTC C INNER JOIN TIM_CONTRATO CT ON C.CONTRATOTC_ID = CT.CONTRATOTC_ID INNER JOIN TIM_DELEGACION DEL ON CT.DELEGACIONTC_ID = DEL.DELEGACIONTC_ID INNER JOIN TIM_EMPLEADO EM ON CT.EMPLEADOTC_ID = EM.EMPLEADOTC_ID INNER JOIN TIM_CLIENTETC CL ON CT.CLIENTETC_ID = CL.CLIENTETC_ID  WHERE C.DELEGACIONTC_ID = 885 AND EXISTS(SELECT 1 FROM TIM_DELEGACIONESDOMICILIOS Y WHERE Y.DOMICILIOCLIENTETC_ID = CT.DOMICILIOCLIENTETC_ID AND Y.DELEGACIONTC_ID = 885) AND CT.ISANULATED_FL <> 1 AND NOT EXISTS ( 	SELECT 1 FROM TIM_FICHAJE Y 	WHERE Y.CONTRATOTC_ID = C.CONTRATOTC_ID 	AND Y.JORNADA_DT = Convert(datetime,CONVERT(DATE,C.ALTA_DT)) 	AND EXISTS(SELECT 1 FROM TIM_DETALLE_FICHAJE X WHERE X.FICHAJE_ID = Y.FICHAJE_ID) ) AND NOT EXISTS(SELECT 1 FROM TIM_INCAPACIDADTEMPORALTC Y 	WHERE Y.CONTRATOTC_ID = C.CONTRATOTC_ID AND ISNULL(Y.ANULADA_FL,0) = 0 	AND C.ALTA_DT >= Y.INICIO_DT 	AND (C.ALTA_DT <=Y.FIN_DT OR Y.FIN_DT IS NULL)) AND NOT EXISTS(SELECT 1 FROM TIM_SUSPENSIONCONTRATOTC Y 	WHERE Y.CONTRATOTC_ID = C.CONTRATOTC_ID 	AND C.ALTA_DT >= Y.INICIO_DT 	AND (C.ALTA_DT <=Y.FIN_DT OR Y.FIN_DT IS NULL)) AND (CONVERT(DATE, C.ALTA_DT) <= CT.FIN_REAL_DT OR CT.FIN_REAL_DT IS NULL) AND ( ( 'D' = 'D' 	AND C.ALTA_DT BETWEEN 			CONVERT(datetime,CONVERT(DATE,{ts '2026-07-06 10:18:06.078'})) 			AND 	 			DATEADD(DD,1,CONVERT(datetime,CONVERT(DATE,{ts '2026-07-06 10:18:06.078'}))) ) OR ( 'D' = 'P' 	AND C.ALTA_DT BETWEEN 			CONVERT(datetime,CONVERT(DATE,NULL)) 			AND 	 			DATEADD(DD,1,CONVERT(datetime,CONVERT(DATE,NULL))) ) ) AND CT.TURNO_ESPECIAL_FL = 1 ORDER BY C.CONTRATOTC_ID 
go

