~    1~AP_CMDELEGACION#107651~CORE_DOFILTER~7C68~06/07/26 10:18:20,665~ejavier.llorente~SELECT COUNT (DISTINCT C.EMPLEADOTC_ID) AS PASS,COUNT (DISTINCT C.CLIENTETC_ID) AS CLIENTES FROM TIM_CONTRATO C WHERE C.ISANULATED_FL = 0 AND C.INICIO_DT <= GETDATE() AND (C.FIN_REAL_DT IS NULL OR C.FIN_REAL_DT >=GETDATE()) AND C.DELEGACIONTC_ID = 885~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~~163~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~163~@_~
~    1~AP_CMDELEGACION#107651~CORE_DOFILTER~7C68~06/07/26 10:18:20,673~ejavier.llorente~SELECT SUM(CASE WHEN A.INICIO_DT < CAST(GETDATE() AS date) THEN A.TOTAL ELSE 0 END) AS POS_VENCIDOS,  SUM(CASE WHEN A.INICIO_DT BETWEEN CAST(GETDATE() AS date) AND DATEADD(DD,6,CAST(GETDATE() AS date)) THEN A.TOTAL ELSE 0 END) AS POS_INMEDIATOS, SUM(CASE WHEN A.INICIO_DT > DATEADD(DD,6,CAST(GETDATE() AS date)) THEN A.TOTAL ELSE 0 END) AS POS_PROXIMOS FROM (     SELECT INICIO_DT,ISNULL(RENOVACION_FL,0) AS RENOVACION,CANTIDAD_NM-     (SELECT COUNT(*) FROM ACP_EMPLEADO_PETICION EP WHERE EP.PETICIONACP_ID = P.PETICIONACP_ID) -     ISNULL((SELECT SUM(H.PLAZAS_NOCUBIERTAS_NM) FROM ACP_NOCUBIERTO_PETICION H WHERE      H.PETICIONACP_ID = P.PETICIONACP_ID),0) AS TOTAL     FROM ACP_PETICIONACP P        WHERE P.ESTADO_CD IN ('PENDIENTE','CURSO','COMPLETADO','CONTRATADO')      AND P.DELEGACIONTC_ID = 885  ) AS A~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~~163~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~163~@_~
~    1~AP_CMDELEGACION#107651~CORE_DOFILTER~7C68~06/07/26 10:18:20,684~ejavier.llorente~SELECT SUM(CASE WHEN A.FIN_PREVISTO_DT < CAST(GETDATE() AS DATE) THEN 1 ELSE 0 END) AS VENCIDAS,  SUM(CASE WHEN A.FIN_PREVISTO_DT BETWEEN CAST(GETDATE() AS DATE) AND DATEADD(DD,2,CAST(GETDATE() AS DATE)) THEN 1 ELSE 0 END) AS PROXIMAS FROM (  SELECT FIN_PREVISTO_DT  FROM TIM_CONTRATO C WHERE C.DELEGACIONTC_ID = 885 AND C.ISANULATED_FL = 0 AND C.FIN_REAL_DT IS NULL AND C.FIN_PREVISTO_DT <= DATEADD(DD,2,CAST(GETDATE() AS DATE)) ) AS A~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~~163~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~163~@_~
~    1~AP_CMDELEGACION#107651~CORE_DOFILTER~7C68~06/07/26 10:18:20,690~ejavier.llorente~SELECT  SUM(CASE WHEN A.EXPIRACION_DT IS NULL OR A.EXPIRACION_DT < CAST(GETDATE() AS DATE) THEN 1 ELSE 0 END) AS CADUCADOS,  SUM(CASE WHEN A.EXPIRACION_DT >= CAST(GETDATE() AS DATE) THEN 1 ELSE 0 END) AS PROX_CADUCIDAD FROM (  SELECT D.EXPIRACION_DT FROM TIM_DOCUMENTACION_EMPLEADO D WHERE D.EMPLEADOTC_ID IN (SELECT C.EMPLEADOTC_ID FROM TIM_CONTRATO C      WHERE C.DELEGACIONTC_ID = 885      AND C.ISANULATED_FL = 0       AND (C.FIN_REAL_DT IS NULL OR C.FIN_REAL_DT >=GETDATE()) ) AND (D.EXPIRACION_DT IS NULL OR D.EXPIRACION_DT <= DATEADD(DD,30,CAST(GETDATE() AS DATE))) AND D.TIPODOCUMENTO_ID IN (1,2) ) AS A~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~~163~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~163~@_~
~    1~AP_CMDELEGACION#107651~CORE_DOFILTER~7C68~06/07/26 10:18:20,703~ejavier.llorente~SELECT COUNT(*) AS BOLETIN_PEND_TOTAL,SUM(ISTIMECAPTURE_FL) AS BOLETIN_PEND_TC FROM ( SELECT CASE WHEN EXISTS(SELECT 1     FROM TIM_DELEGACIONESDOMICILIOS DD     WHERE DD.DELEGACIONTC_ID = B.DELEGACIONTC_ID     AND DD.DOMICILIOCLIENTETC_ID = CT.DOMICILIOCLIENTETC_ID     AND DD.IS_TIME_CAPTURE_FL = 1 ) THEN 1 ELSE 0 END AS ISTIMECAPTURE_FL FROM TIM_BOLETIN B  INNER JOIN TIM_CONTRATO CT ON CT.CONTRATOTC_ID = B.CONTRATOTC_ID WHERE B.ESTADO_CD = 'PENDIENTE'  AND B.DELEGACIONTC_ID = 885  AND B.FIN_DT BETWEEN (SELECT DATEADD(MONTH,1,MES_CERRADO_DT) FROM TIM_DELEGACION WHERE DELEGACIONTC_ID = 885) AND DATEADD(DD,-1,GETDATE()) AND B.BOLETIN_ORIGEN_ID IS NULL) AS A ~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~~163~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~163~@_~
~    1~AP_CMDELEGACION#107651~CORE_DOFILTER~7C68~06/07/26 10:18:20,723~ejavier.llorente~SELECT COUNT(DISTINCT E.EMPLEADOTC_ID) AS FORMACION_PRL_PEND FROM TIM_EMPLEADO E INNER JOIN TIM_CONTRATO C ON E.EMPLEADOTC_ID = C.EMPLEADOTC_ID INNER JOIN TIM_FORMACIONCURSOS X ON X.EMPLEADOTC_CD = E.EMPLEADOTC_CD AND X.TIPO_CODIGO_CD = E.TIPO_CODIGO_CD WHERE C.DELEGACIONTC_ID = 885 AND C.INICIO_DT < GETDATE() AND ISNULL(C.ISANULATED_FL,0) = 0 AND (C.FIN_REAL_DT >= CONVERT(datetime, CONVERT(date, GETDATE())) OR C.FIN_REAL_DT IS NULL) AND X.TIPOCURSO_DS = 'PRL/Online' AND (X.EXPIRACION_DT > GETDATE() OR X.EXPIRACION_DT IS NULL) AND ISNULL(X.ESTADOCURSO_DS,'') NOT IN ('Completado','Finalizado')~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~~163~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~163~@_~
~    1~AP_CMDELEGACION#107651~CORE_DOFILTER~7C68~06/07/26 10:18:20,740~ejavier.llorente~SELECT COUNT(DISTINCT E.EMPLEADOTC_ID) AS FORMACION_PRL_PROX_CADUCIDAD FROM TIM_EMPLEADO E INNER JOIN TIM_CONTRATO C ON E.EMPLEADOTC_ID = C.EMPLEADOTC_ID INNER JOIN TIM_FORMACIONCURSOS X ON X.EMPLEADOTC_CD = E.EMPLEADOTC_CD AND X.TIPO_CODIGO_CD = E.TIPO_CODIGO_CD WHERE C.DELEGACIONTC_ID = 885  AND C.INICIO_DT < GETDATE() AND ISNULL(C.ISANULATED_FL,0) = 0 AND (C.FIN_REAL_DT >= CONVERT(datetime, CONVERT(date, GETDATE())) OR C.FIN_REAL_DT IS NULL) AND X.TIPOCURSO_DS = 'PRL/Online' AND DATEDIFF(DAY,CAST(GETDATE() AS DATE),X.EXPIRACION_DT) < 60~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~~163~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~163~@_~
~    1~AP_CMDELEGACION#107651~CORE_DOFILTER~7C68~06/07/26 10:18:20,754~ejavier.llorente~SELECT COUNT(DISTINCT E.EMPLEADOTC_ID) AS FORMACION_PRL_METAL FROM TIM_CONTRATO C INNER JOIN TIM_EMPLEADO E ON E.EMPLEADOTC_ID = C.EMPLEADOTC_ID WHERE C.DELEGACIONTC_ID = 885 AND C.ISANULATED_FL = 0 AND (C.FIN_REAL_DT IS NULL OR C.FIN_REAL_DT >=GETDATE()) AND EXISTS(SELECT 1 FROM TIM_CLIENTETC CL WHERE CL.CLIENTETC_ID = C.CLIENTETC_ID  AND CL.SECTOR_ACTIVIDAD_ID IN (SELECT SA.SECTOR_ACTIVIDAD_ID FROM TIM_SECTOR_ACTIVIDAD SA WHERE SA.FORMACION_METAL_FL = 1)) AND EXISTS(SELECT 1 FROM TIM_DOMICILIOCLIENTETC DC WHERE DC.DOMICILIOCLIENTETC_ID = C.DOMICILIOCLIENTETC_ID AND DC.EXENTO_METAL_DOC_ID IS NULL) AND NOT EXISTS(SELECT 1 FROM TIM_DOCUMENTACION_EMPLEADO DE WHERE DE.EMPLEADOTC_ID = E.EMPLEADOTC_ID AND DE.TIPODOCUMENTO_ID IN (SELECT TD.TIPODOCUMENTO_ID FROM TIM_TIPODOCUMENTO TD WHERE TD.FORMACION_METAL_FL = 1)AND DE.ESTADO_CD IN ('VALIDADO_OCR', 'VALIDADO_DELEGACION') AND (DE.EXPIRACION_DT IS NULL OR EXPIRACION_DT > C.INICIO_DT))~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~~163~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~163~@_~
~    1~AP_CMDELEGACION#107651~CORE_DOFILTER~7C68~06/07/26 10:18:20,781~ejavier.llorente~SELECT SUM(X.ACTIVO_FL) AS ACTIVOS_FD,SUM(X.INACTIVO_FL) AS INACTIVOS_FD FROM ( SELECT CASE WHEN EXISTS(SELECT 1 FROM TIM_CONTRATO C     WHERE C.EMPLEADOTC_ID = E.EMPLEADOTC_ID     AND C.ISANULATED_FL = 0    AND C.DELEGACIONTC_ID = 885    AND C.SUPUESTO_DS = 'IFJ'    AND C.FIN_REAL_DT IS NULL ) THEN 1 ELSE 0 END AS ACTIVO_FL, CASE WHEN EXISTS (SELECT 1 FROM ACP_CONTRATO XX_ACP_CONTRATO INNER JOIN ACP_EMPLEADO_PETICION XX_ACP_EMPLEADO_PETICION ON XX_ACP_EMPLEADO_PETICION.MOTIVOSFIN_ACP_ID = 6 AND XX_ACP_EMPLEADO_PETICION.EMPLEADO_PETICIONACP_ID = XX_ACP_CONTRATO.EMPLEADO_PETICIONACP_ID WHERE XX_ACP_CONTRATO.CONTRATOTC_ID = ( SELECT XX_TIM_CONTRATO.CONTRATOTC_ID FROM TIM_CONTRATO XX_TIM_CONTRATO     CROSS APPLY (SELECT TOP 1 C.CONTRATOTC_ID FROM TIM_CONTRATO C WHERE C.EMPLEADOTC_ID = E.EMPLEADOTC_ID       AND C.ISANULATED_FL = 0 AND C.FIN_REAL_DT IS NOT NULL       ORDER BY C.FIN_REAL_DT DESC) XX_ULTIMO_CONTRATO    WHERE XX_ULTIMO_CONTRATO.CONTRATOTC_ID = XX_TIM_CONTRATO.CONTRATOTC_ID AND XX_TIM_CONTRATO.SUPUESTO_DS = 'IFJ'       AND XX_TIM_CONTRATO.DELEGACIONTC_ID = 885)       AND XX_ACP_CONTRATO.ESTADO_CD <> 'ANULADO' AND NOT EXISTS(SELECT 1 FROM TIM_CONTRATO C WHERE          C.EMPLEADOTC_ID = E.EMPLEADOTC_ID AND C.ISANULATED_FL = 0          AND C.FIN_REAL_DT IS NULL) ) THEN 1 ELSE 0 END AS INACTIVO_FL FROM TIM_EMPLEADO E WHERE EXISTS(SELECT 1 FROM TIM_DELEGACIONESEMPLEADOS DE WHERE DE.EMPLEADOTC_ID = E.EMPLEADOTC_ID AND DE.DELEGACIONTC_ID = 885) ) X~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~~163~D:\ADSP\SERVICES\ADECCO4U\Program\AdeccoOleBasCore\funciones\f_globalestcoledb.cor~163~@_~
